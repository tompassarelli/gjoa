#lang beagle/js
;; `gjoa preflight` — the gate that runs before any nix build is allowed.
;;
;; Per CLAUDE.md Rule #0: Claude may not propose a rebuild without
;; showing this script's output. Gates are MECHANICAL. New failure
;; modes get added here, not to a mental checklist that gets skipped.
;;
;; Exits 0 if every gate passes, 1 if any gate fails. Gate F (daemon
;; settings) and Gate G (nix eval) are the two that would have caught
;; the 2026-05-26 failure.
(ns gjoa.tools.scripts.preflight
  (:require [fs :refer [existsSync readFileSync readdirSync]]
            [child_process :refer [execSync]]
            [path :refer [join basename]]
            [gjoa.tools.prep.symbol-resolve :refer [check-contract]]))
(define-mode strict)
(declare-extern [process JSON RegExp Object Set Array] Any)

;; The old .ts used `resolve(import.meta.dir, "..", "..")` to climb from
;; tools/scripts/ to the repo root. There is no import.meta in beagle, and
;; these tools run via `bun run` from the repo root, so cwd IS the repo root.
(def REPO-ROOT :- String (.cwd process))
(def ENGINE-DIR :- String (join REPO-ROOT "engine"))
(def FLAKE :- String (join REPO-ROOT "flake.nix"))
(def PATCHES-DIR :- String (join REPO-ROOT "patches"))
(def GJOA-JSON :- String (join REPO-ROOT "gjoa.json"))
(def LEDGER :- String (join REPO-ROOT "BUILD-LEDGER.md"))
(def NIX-RESULT :- String (join REPO-ROOT "result" "bin" "gjoa"))

(def tty :- Any (.-isTTY (.-stdout process)))
(defn c [s :- String code :- String] :- String
  (if tty (str "[" code "m" s "[0m") s))
(defn green [s :- String] :- String (c s "32"))
(defn red [s :- String] :- String (c s "31"))
(defn yellow [s :- String] :- String (c s "33"))
(defn dim [s :- String] :- String (c s "2"))
(defn bold [s :- String] :- String (c s "1"))

;; Accumulated GateResult records (plain JS objects):
;;   {:id :name :passed :warned :detail :fix}
(def results :- Any [])

(defn pass [id :- String name :- String detail :- String] :- Any
  (.push results {:id id :name name :passed true :detail detail}))
(defn fail [id :- String name :- String detail :- String fix :- String] :- Any
  (.push results {:id id :name name :passed false :detail detail :fix fix}))
;; A WARN does not fail the gate (passed: true) but flags a non-fatal,
;; inconclusive result the operator should be aware of — e.g. a nix eval that
;; timed out rather than genuinely failed.
(defn warn [id :- String name :- String detail :- String] :- Any
  (.push results {:id id :name name :passed true :warned true :detail detail}))

(defn sh [cmd :- String opts :- Any] :- Any
  (try
    (let [out (execSync cmd {:encoding "utf8"
                             :timeout (or (.-timeout opts) 30000)
                             :stdio ["ignore" "pipe" "pipe"]})]
      {:ok true :out out})
    (catch Error e
      ;; A timeout (execSync sends SIGTERM and sets code 'ETIMEDOUT') is not a
      ;; real failure of the command — surface it so callers can WARN/skip
      ;; rather than treat it as a hard error.
      (let [timedOut (or (= (.-code e) "ETIMEDOUT") (= (.-signal e) "SIGTERM"))
            stderr (if (.-stderr e) (.toString (.-stderr e)) "")
            stdout (if (.-stdout e) (.toString (.-stdout e)) "")]
        {:ok false
         :timedOut timedOut
         :out (or (str stderr stdout) (.-message e))}))))

;; ── Gate A: patches apply cleanly against fresh source ─────────────────────
(defn gateA [] :- Any
  (let [cache (str (.-HOME (.-env process)) "/.cache/gjoa/sources")
        gjoa (JSON/parse (readFileSync GJOA-JSON "utf8"))
        tarball (str cache "/firefox-" (.-version (.-firefox gjoa)) ".source.tar.xz")]
    (if (not (existsSync tarball))
      (fail "A" "patches apply clean on fresh source"
        (str "tarball not cached at " tarball)
        "run `bun run download` to populate the cache")
      (let [tmp "/tmp/gjoa-preflight-engine"]
        (sh (str "rm -rf " tmp " && mkdir -p " tmp) {})
        (let [extract (sh (str "tar -xJf " tarball " -C " tmp " --strip-components=1") {:timeout 180000})]
          (if (not (.-ok extract))
            (fail "A" "patches apply clean on fresh source" "tarball extract failed" (.slice (.-out extract) 0 400))
            (do
              (sh (str "cd " tmp " && git init -q && git add -A && git -c user.email=t@t -c user.name=t commit -q -m baseline") {:timeout 60000})
              (let [patches (.sort (.filter (readdirSync PATCHES-DIR) (fn [p] (.endsWith p ".patch"))))
                    failed []
                    drifted []]
                (doseq [p patches]
                  (let [path (join PATCHES-DIR p)
                        r (sh (str "cd " tmp " && git apply --check " path) {})]
                    (if (not (.-ok r))
                      (.push failed (str p ": " (.trim (or (aget (.split (.-out r) "\n") 0) ""))))
                      ;; Applies clean via git apply — now detect line-offset DRIFT,
                      ;; the early warning the .rej arrives a release after. GNU patch
                      ;; reports "Hunk #N succeeded at M (offset L lines)" for drift
                      ;; that git apply tolerates silently. Take the largest |offset|.
                      (let [pr (sh (str "cd " tmp " && patch -p1 --dry-run --fuzz=0 --force -i " path " 2>&1 | grep -oiE 'offset -?[0-9]+' | grep -oE '[0-9]+' | sort -rn | head -1") {})
                            off (parseInt (.trim (or (.-out pr) "")) 10)]
                        (when (> off 0)
                          (.push drifted (str p " (offset " off ")")))))))
                (cond
                  (> (.-length failed) 0)
                  (fail "A" "patches apply clean on fresh source"
                    (str (.-length failed) "/" (.-length patches) " patches fail")
                    (str "regenerate each failing patch via `git diff` in a fresh extract:\n    " (.join failed "\n    ")))
                  (> (.-length drifted) 0)
                  (warn "A" "patches apply clean on fresh source"
                    (str (.-length patches) "/" (.-length patches) " apply, but " (.-length drifted) " drifting on line-offset (early warning — regenerate before they .rej): " (.join drifted ", ")))
                  :else
                  (pass "A" "patches apply clean on fresh source" (str (.-length patches) "/" (.-length patches) " apply clean, no drift")))))))))))

;; ── Gate B: chrome registration uses a known-working pattern ──────────────
(defn gateB [] :- Any
  (let [ours (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "jar.mn")]
    (if (not (existsSync ours))
      (fail "B" "jar.mn pattern matches working example"
        (str ours " missing")
        "restore from git")
      (let [content (readFileSync ours "utf8")
            usesBrowserJar (.test (RegExp. "^browser\\.jar:" "m") content)
            hasContentDecl (.test (RegExp. "^% content\\s+gjoa\\s+%content/gjoa/" "m") content)]
        (cond
          (not usesBrowserJar)
          (fail "B" "jar.mn pattern matches working example"
            "uses `<package>.jar:` syntax — silently no-op in modern Firefox"
            "change first non-comment line to `browser.jar:` (see browser/branding/unofficial/content/jar.mn)")

          (not hasContentDecl)
          (fail "B" "jar.mn pattern matches working example"
            "no `% content gjoa %content/gjoa/` registration line"
            "add `% content gjoa %content/gjoa/` after `browser.jar:`")

          :else
          (pass "B" "jar.mn pattern matches working example" "browser.jar: + % content gjoa %content/gjoa/"))))))

;; ── Gate C: no production-mode TODO/no-op landmines ───────────────────────
(defn gateC [] :- Any
  (let [prodFiles ["src/gjoa/browser/components/gjoa/GjoaLoader.sys.mjs"
                   "src/gjoa/chrome/bjs/security/index.bjs"
                   "src/gjoa/chrome/bjs/drawer/index.bjs"
                   "src/gjoa/chrome/bjs/spaces/index.bjs"
                   "src/gjoa/chrome/bjs/tabs/index.bjs"]
        landmines []
        stub-return (RegExp. "^\\s*return\\s*;?\\s*//\\s*(TODO|FIXME|future)" "i")
        stub-comment (RegExp. "//\\s*(future commit|nothing yet|not yet implemented)" "i")]
    (doseq [f prodFiles]
      (let [path (join REPO-ROOT f)]
        (when (existsSync path)
          (let [lines (.split (readFileSync path "utf8") "\n")]
            ;; Only flag literal "TODO" / "future commit" / "nothing yet" inside
            ;; executable code (not in jsdoc/regular comments that describe
            ;; intent). Heuristic: line ends with `return;` or matches the
            ;; specific dead-stub pattern.
            (.forEach lines
              (fn [l i]
                (when (or (.test stub-return l) (.test stub-comment l))
                  (.push landmines (str f ":" (+ i 1) ": " (.trim l))))))))))
    (if (> (.-length landmines) 0)
      (fail "C" "no production-mode TODO/no-op landmines"
        (str (.-length landmines) " suspicious dead-stub markers in production paths")
        (str "audit + implement or delete each:\n    " (.join landmines "\n    ")))
      (pass "C" "no production-mode TODO/no-op landmines" (str (.-length prodFiles) " prod files scanned, none flagged")))))

;; ── Gate D: dep floors satisfied ──────────────────────────────────────────
(defn gateD [] :- Any
  (let [flakeContent (readFileSync FLAKE "utf8")
        minNssMatch (.match flakeContent (RegExp. "minNssVersion\\s*=\\s*\"([^\"]+)\""))
        minNss (if minNssMatch (aget minNssMatch 1) nil)]
    (if (nil? minNss)
      (pass "D" "dep floors satisfied" "no minNssVersion gate declared")
      (let [probe (sh
                    (str "nix eval --impure --raw --expr '(import (builtins.getFlake \"git+file://" REPO-ROOT "\").inputs.nixpkgs { system = \"x86_64-linux\"; }).nss_latest.version' 2>&1")
                    {:timeout 60000})]
        (if (not (.-ok probe))
          (fail "D" "dep floors satisfied" "could not probe nixpkgs nss_latest.version"
            (str "fix the nix eval error and re-run:\n" (.slice (.-out probe) -300)))
          ;; compareVersions: if nixpkgs >= minNss, overlay short-circuits (good).
          ;; if behind, our overlay activates and Mozilla tarball is fetched.
          (let [nixpkgsNss (.pop (.split (.trim (.-out probe)) "\n"))]
            (pass "D" "dep floors satisfied"
              (str "minNssVersion=" minNss ", nixpkgs nss_latest=" nixpkgsNss " → overlay "
                   ;; Original did a naive JS string `>=`; beagle's `>=` is
                   ;; numeric, so replicate lexicographic comparison via
                   ;; localeCompare (>= 0 means nixpkgsNss >= minNss).
                   (if (>= (.localeCompare (String nixpkgsNss) (String minNss)) 0) "auto-disabled" "ACTIVE (will fetch Mozilla tarball)")))))))))

;; ── Gate E: existing binary status (informational gate) ───────────────────
(defn gateE [] :- Any
  (if (not (existsSync NIX-RESULT))
    (pass "E" "existing binary status" "no result/ symlink (fresh rebuild)")
    (let [omni (join REPO-ROOT "result" "lib" "gjoa" "browser" "omni.ja")]
      (if (not (existsSync omni))
        (pass "E" "existing binary status" "result/ exists but no omni.ja (probably broken — rebuild)")
        (let [r (sh (str "unzip -p " omni " chrome/chrome.manifest 2>/dev/null | grep -c \"^content gjoa\" || true") {})
              count (or (parseInt (.trim (.-out r)) 10) 0)]
          (if (> count 0)
            ;; Binary already has the registration — rebuild only needed if you've
            ;; actually changed something that affects it.
            (pass "E" "existing binary status" (str "current result/ has " count " `content gjoa` line(s); rebuild is REPLACING a working binary"))
            (pass "E" "existing binary status" "current result/ has NO `content gjoa` registration — rebuild needed to restore chrome bundles")))))))

;; ── Gate F: nix daemon will accept flake settings ─────────────────────────
;;
;; Two separate nix permission mechanisms get conflated easily:
;;   * trusted-users  → who can pass --option / --no-sandbox FLAGS at CLI
;;   * sandbox=true   → rejects ANY derivation with `__noChroot=true`
;;                      regardless of who's invoking
;;
;; For `__noChroot = true` to actually take effect, the daemon's
;; `sandbox` setting must be `relaxed` (or `false`). `sandbox = true`
;; rejects it at eval time even for trusted users. This gate caught
;; me on 2026-05-26 — see BUILD-LEDGER postmortem.
(defn gateF [] :- Any
  ;; Strip nix comment lines before matching so we don't false-positive
  ;; on `__noChroot = true` written inside an explanation comment.
  (let [flakeContent (.join
                       (.filter (.split (readFileSync FLAKE "utf8") "\n")
                                (fn [l] (not (.test (RegExp. "^\\s*#") l))))
                       "\n")
        usesNoChroot (.test (RegExp. "__noChroot\\s*=\\s*true") flakeContent)
        usesImpure (.test (RegExp. "__impure\\s*=\\s*true") flakeContent)]
    (if (and (not usesNoChroot) (not usesImpure))
      (pass "F" "nix daemon will accept flake settings" "no privileged settings in flake.nix")
      (let [cfg (sh "nix show-config 2>/dev/null" {:timeout 15000})
            sandboxLine (or (.find (.split (.-out cfg) "\n")
                                   (fn [l] (.test (RegExp. "^sandbox = ") l))) "")
            sandbox (.trim (or (aget (.split sandboxLine "=") 1) ""))]
        (if (and usesNoChroot (= sandbox "true"))
          (fail "F" "nix daemon will accept flake settings"
            "flake uses __noChroot but daemon has sandbox=true → rejected at eval"
            "either:\n      (a) remove __noChroot from flake.nix (Lane 1 edit; lose sccache persistence), or\n      (b) change sandbox = \"relaxed\" in nixos-config nix-settings module + firn rebuild")
          (pass "F" "nix daemon will accept flake settings"
            (str "sandbox=" sandbox " permits __noChroot/__impure")))))))

;; ── Gate G: nix flake evaluates without errors ────────────────────────────
(defn gateG [] :- Any
  (let [r (sh
            (str "nix eval --impure --raw '" REPO-ROOT "#gjoa.outPath' 2>&1")
            {:timeout 120000})]
    (if (not (.-ok r))
      (if (.-timedOut r)
        ;; A dirty git tree defeats nix's eval cache, so eval can be slow without
        ;; being broken. Don't fail the gate on a wall-clock timeout.
        (warn "G" "nix flake evaluates without errors"
          "nix eval timed out — not a real eval failure; re-run with a clean tree or longer timeout")
        (fail "G" "nix flake evaluates without errors"
          "evaluation failed — would have died during build"
          (.join (.slice (.filter (.split (.-out r) "\n")
                                  (fn [l] (.includes (.toLowerCase l) "error"))) 0 5) "\n      ")))
      (pass "G" "nix flake evaluates without errors" (str "derivation resolves to " (.slice (.pop (.split (.trim (.-out r)) "\n")) -50))))))

;; ── Gate H: diff since last working build ─────────────────────────────────
(defn gateH [] :- Any
  (if (not (existsSync LEDGER))
    (pass "H" "diff since last working build" "no ledger yet (first build)")
    (let [ledger (readFileSync LEDGER "utf8")
          lastSuccess (.find (.split ledger "\n")
                             (fn [l] (and (.test (RegExp. "^\\|\\s*\\d{4}-\\d{2}-\\d{2}") l)
                                          (.test (RegExp. "success|works" "i") l)
                                          (not (.test (RegExp. "broken|fail" "i") l)))))]
      (if (nil? lastSuccess)
        (pass "H" "diff since last working build" "no successful build logged yet")
        ;; Find last commit before that date (approximate)
        (let [dateMatch (.match lastSuccess (RegExp. "^\\|\\s*(\\d{4}-\\d{2}-\\d{2})"))
              date (or (if dateMatch (aget dateMatch 1) nil) "")]
          (sh (str "git log --oneline --since='" date "' --until='now' --pretty=format:'%h %s' 2>&1 | head -30") {})
          (let [changed (sh "git diff --name-only HEAD~5..HEAD 2>&1 | head -50" {})
                lines (.filter (.split (.-out changed) "\n") (fn [x] x))]
            (pass "H" "diff since last working build"
              (str (.-length lines) " files changed in recent commits (review for prereqs):\n      "
                   (.join (.slice lines 0 15) "\n      ")
                   (if (> (.-length lines) 15) (str "\n      ... and " (- (.-length lines) 15) " more") "")))))))))

;; ── Gate I: chrome bundle three-way alignment ─────────────────────────────
(defn gateI [] :- Any
  (let [loaderPath (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "GjoaLoader.bjs")
        jarPath (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "jar.mn")
        bakePath (join REPO-ROOT "tools" "prep" "chrome-bake.bjs")]
    (if (not (.every [loaderPath jarPath bakePath] existsSync))
      (fail "I" "chrome bundle three-way alignment" "one of loader/jar/bake missing" "investigate")
      (let [loader (readFileSync loaderPath "utf8")
            jar (readFileSync jarPath "utf8")
            bake (readFileSync bakePath "utf8")
            loaderScripts (.sort (.map (Array/from (.matchAll loader (RegExp. "\"(gjoa-[a-z-]+\\.uc\\.js)\"" "g"))) (fn [m] (aget m 1))))
            jarScripts (.sort (.filter (.map (Array/from (.matchAll jar (RegExp. "scripts/(gjoa-[a-z-]+\\.uc\\.js)" "g"))) (fn [m] (aget m 1)))
                                       (fn [v i a] (= (.indexOf a v) i))))
            bakeScripts (.sort (.map (Array/from (.matchAll bake (RegExp. "\"(gjoa-[a-z-]+\\.uc\\.js)\"" "g"))) (fn [m] (aget m 1))))
            ;; CSS bundles include the bare `gjoa.uc.css` (no hyphen suffix), so the
            ;; style pattern must allow an optional `-...` segment.
            loaderStyles (.sort (.map (Array/from (.matchAll loader (RegExp. "\"(gjoa(?:-[a-z-]+)?\\.uc\\.css)\"" "g"))) (fn [m] (aget m 1))))
            jarStyles (.sort (.filter (.map (Array/from (.matchAll jar (RegExp. "styles/(gjoa(?:-[a-z-]+)?\\.uc\\.css)" "g"))) (fn [m] (aget m 1)))
                                      (fn [v i a] (= (.indexOf a v) i))))
            bakeStyles (.sort (.map (Array/from (.matchAll bake (RegExp. "\"(gjoa(?:-[a-z-]+)?\\.uc\\.css)\"" "g"))) (fn [m] (aget m 1))))
            eq (fn [a :- Any b :- Any]
                 (and (= (.-length a) (.-length b))
                      (.every a (fn [x i] (= x (aget b i))))))]
        (cond
          (or (not (eq loaderScripts jarScripts)) (not (eq loaderScripts bakeScripts)))
          (fail "I" "chrome bundle three-way alignment"
            (str "script lists differ:\n      loader: " (.join loaderScripts ", ") "\n      jar:    " (.join jarScripts ", ") "\n      bake:   " (.join bakeScripts ", "))
            "align all three so they declare the exact same .uc.js filenames")

          (or (not (eq loaderStyles jarStyles)) (not (eq loaderStyles bakeStyles)))
          (fail "I" "chrome bundle three-way alignment"
            (str "style lists differ:\n      loader: " (.join loaderStyles ", ") "\n      jar:    " (.join jarStyles ", ") "\n      bake:   " (.join bakeStyles ", "))
            "align all three so they declare the exact same .uc.css filenames")

          :else
          (pass "I" "chrome bundle three-way alignment"
            (str (.-length loaderScripts) " script + " (.-length loaderStyles) " style bundles agree across loader / jar.mn / chrome-bake.bjs")))))))

;; ── Gate J: vendored scriptlet bundle matches its pinned SHA-256 ──────────
;; scriptlet-resources.json is base64-encoded JS run via evalInSandbox on the
;; privileged side of the content classifier; a swapped/tampered bundle injects
;; attacker JS into pages. Assert it still matches the digest recorded in
;; scriptlet-resources.PROVENANCE.md (security finding F10).
(defn gateJ [] :- Any
  (let [script (join REPO-ROOT "tools" "prep" "verify-scriptlet-resources.sh")]
    (if (not (existsSync script))
      (fail "J" "scriptlet bundle integrity" "verify-scriptlet-resources.sh missing" "restore the F10 verifier")
      (let [r (sh (str "bash " script) {})]
        (if (.-ok r)
          (pass "J" "scriptlet bundle integrity" "scriptlet-resources.json matches the pinned SHA-256")
          (fail "J" "scriptlet bundle integrity"
            (.trim (or (.-out r) "digest mismatch"))
            "if you refreshed the bundle from a pinned uBO commit, update the SHA-256 in verify-scriptlet-resources.sh AND scriptlet-resources.PROVENANCE.md"))))))

;; ── Gate K: engine/ reflects current source (import-currency) ───────────────
;; The compile input is engine/ (gitignored), which only mirrors src/gjoa/ +
;; patches/ + the import tooling AFTER `bun run import`. Every stale-engine
;; catastrophe — e.g. the 2026-06-14 build that compiled a 3-week-old tree, ran
;; green, and silently dropped every recent change — is this gate's failure
;; mode. `import` stamps engine/.gjoa-import-stamp at completion; if any source
;; tree is newer than that stamp, engine/ is stale and must be re-imported.
(def IMPORT-STAMP :- String (join ENGINE-DIR ".gjoa-import-stamp"))
(defn gateK [] :- Any
  (if (not (existsSync IMPORT-STAMP))
    (fail "K" "engine/ reflects current source (import-currency)"
      "no engine/.gjoa-import-stamp — engine/ is unimported (or predates this gate)"
      "run `bun run import` to (re)build engine/ from src/gjoa/ + patches/")
    (let [stamp-r (sh (str "stat -c %Y '" IMPORT-STAMP "'") {})
          newest-r (sh "find src/gjoa patches tools/prep -type f -printf '%T@\\n' 2>/dev/null | sort -rn | head -1" {})
          stamp-out (.trim (or (.-out stamp-r) ""))
          newest-out (.trim (or (.-out newest-r) ""))]
      (if (or (not (.-ok stamp-r)) (not (.-ok newest-r)) (= stamp-out "") (= newest-out ""))
        (warn "K" "engine/ reflects current source (import-currency)"
          "could not determine source/stamp mtimes — skipping (non-fatal)")
        (if (> (parseInt newest-out 10) (parseInt stamp-out 10))
          (fail "K" "engine/ reflects current source (import-currency)"
            "src/gjoa/, patches/, or tools/prep/ changed since the last `bun run import`"
            "run `bun run import` — the build compiles engine/, not src/, so un-imported edits silently vanish from the binary")
          (pass "K" "engine/ reflects current source (import-currency)"
            "no src/patches/tooling edits since the last import"))))))

;; ── Gate L: surface contracts (declared upstream deps still resolve) ────────
;; A patch/overlay DEPENDS ON upstream symbols it references but does not patch
;; (a Rust path, a generated style-struct accessor, a JS object property). git
;; apply (Gate A) is blind to these — they're added tokens, not context — so a
;; MOVE/REMOVAL passes apply and dies 26 min into the compile (ComputedValueFlags
;; module move; background_image field removal) or ships a silent no-op
;; (FF152 deleting AboutNewTab.newTabURL). A `# depends-on:` / `;; @gjoa-depends-on`
;; block declares those anchors; Gate L resolves each against engine/, RED before
;; the build if one vanished. Design: private-docs/research-fork-currency-gate-l.md.
(def OVERLAY-FILES :- Any
  [(join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "GjoaLoader.bjs")])
(defn gateL [] :- Any
  (let [patch-files (.map (.filter (readdirSync PATCHES-DIR) (fn [p :- String] :- Bool (.endsWith p ".patch")))
                          (fn [p :- String] :- String (join PATCHES-DIR p)))
        files (.concat patch-files (.filter OVERLAY-FILES (fn [f :- String] :- Bool (existsSync f))))
        not-found []
        ambiguous []
        resolved []]
    (doseq [f files]
      (doseq [r (check-contract (readFileSync f "utf8"))]
        (cond
          (= (.-verdict r) "not-found")
          (.push not-found (str (basename f) ": " (.-kind r) " `" (.-symbol r) "` — " (.-detail r)))
          (= (.-verdict r) "ambiguous")
          (.push ambiguous (str (basename f) ": " (.-symbol r)))
          :else (.push resolved (.-symbol r)))))
    (cond
      (> (.-length not-found) 0)
      (fail "L" "surface contracts (declared upstream deps resolve)"
        (str (.-length not-found) " declared dependency(ies) no longer resolve")
        (str "the upstream anchor moved/was removed — regenerate the patch/overlay against current upstream:\n    " (.join not-found "\n    ")))
      (> (.-length ambiguous) 0)
      (warn "L" "surface contracts (declared upstream deps resolve)"
        (str (.-length resolved) " resolved, " (.-length ambiguous) " ambiguous (cfg/glob/no-objdir — can't prove): " (.join ambiguous ", ")))
      :else
      (pass "L" "surface contracts (declared upstream deps resolve)"
        (str (.-length resolved) " declared upstream dependencies resolve")))))

;; ── Gate M: beagle compiler pinned (beagle-currency) ───────────────────────
;; gjoa compiles against ../beagle directly (no submodule), so WHATEVER branch that
;; checkout is on silently determines the compiler — non-reproducible, and exactly
;; how a parked beagle branch can change gjoa's build with no reference anywhere.
;; configs/beagle.ref records the expected ref; WARN (not fail) on drift so the
;; co-dev workflow (iterating on beagle) isn't blocked — but the drift is visible,
;; and the build fingerprint bakes the ACTUAL ref. Bump the pin deliberately.
(def BEAGLE-REF-FILE :- String (join REPO-ROOT "configs" "beagle.ref"))
(defn gateM [] :- Any
  (if (not (existsSync BEAGLE-REF-FILE))
    (warn "M" "beagle compiler pinned (beagle-currency)"
      "no configs/beagle.ref — gjoa builds against whatever ../beagle is checked out on (non-reproducible)")
    (let [lines (.split (readFileSync BEAGLE-REF-FILE "utf8") "\n")
          pinned (.trim (or (.find lines (fn [l :- String] :- Bool
                                           (and (> (.-length (.trim l)) 0)
                                                (not (.startsWith (.trim l) "#"))))) ""))
          r (sh "git -C ../beagle rev-parse HEAD" {})
          actual (.trim (or (.-out r) ""))]
      (cond
        (= pinned "") (warn "M" "beagle compiler pinned (beagle-currency)"
                        "configs/beagle.ref has no ref line")
        (or (not (.-ok r)) (= actual "")) (warn "M" "beagle compiler pinned (beagle-currency)"
                                            "could not read ../beagle HEAD — skipping (non-fatal)")
        (.startsWith actual pinned) (pass "M" "beagle compiler pinned (beagle-currency)"
                                      (str "../beagle at pinned ref " (.slice pinned 0 12)))
        :else (warn "M" "beagle compiler pinned (beagle-currency)"
                (str "../beagle HEAD " (.slice actual 0 12) " != pinned " (.slice pinned 0 12)
                     " — compiling against a different beagle than pinned; bump configs/beagle.ref deliberately (review the beagle changelog) or checkout the pin"))))))

;; ── Gate N: knobs backed + reversible (knob-not-delete) ────────────────────
;; Every knob about:gjoa exposes (settings/registry.json) must be backed by a pref
;; actually SET in source. A dangling knob — whose feature was deleted but whose
;; toggle remains — is a no-op that lies to the user; this gate makes that deletion
;; impossible to ship silently (restore the pref, reversibly, or remove the knob).
;; Also asserts the registry privacy-profile `sets` prefs == GjoaLoader's
;; PRIVACY-PRESETS prefs, so the picker sets exactly what the loader applies.
(def REGISTRY-FILE :- String
  (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "content" "settings" "registry.json"))
(def LOADER-FILE :- String
  (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "GjoaLoader.bjs"))
(def PREF-DIR :- String (join REPO-ROOT "src" "gjoa" "defaults" "pref"))

(defn quoted-strings [s :- String] :- Any
  (let [m (.match s (RegExp. "\"[^\"]+\"" "g"))]
    (if m (.map m (fn [q :- String] :- String (.slice q 1 -1))) [])))

(defn preset-pref-names [loader :- String] :- Any
  ;; pref-names referenced in the PRIVACY-PRESETS def: quoted strings containing a
  ;; "." (pref names have dots; "bool"/"int" and the profile-id keys don't).
  (let [start (.indexOf loader "(def PRIVACY-PRESETS")
        end (.indexOf loader "(defn apply-privacy-profile!")
        block (if (and (>= start 0) (> end start)) (.slice loader start end) "")]
    (.filter (quoted-strings block) (fn [q :- String] :- Bool (.includes q ".")))))

(defn gateN [] :- Any
  (if (not (and (existsSync REGISTRY-FILE) (existsSync LOADER-FILE) (existsSync PREF-DIR)))
    (warn "N" "knobs backed + reversible (knob-not-delete)"
      "no about:gjoa registry/loader/prefs — skipping")
    (let [reg (JSON/parse (readFileSync REGISTRY-FILE "utf8"))
          loader (readFileSync LOADER-FILE "utf8")
          pref-src (.join (.map (.filter (readdirSync PREF-DIR) (fn [f :- String] :- Bool (.endsWith f ".bjs")))
                                (fn [f :- String] :- String (readFileSync (join PREF-DIR f) "utf8"))) "\n")
          src (str pref-src "\n" loader)
          pv (.-privacy reg)
          sel (and pv (.-selector pv))
          profiles (or (and sel (.-profiles sel)) [])
          knob-prefs []
          _g (doseq [g (or (and pv (.-granular pv)) [])] (.push knob-prefs (.-pref g)))
          _ps (doseq [p profiles] (doseq [k (Object/keys (.-sets p))] (.push knob-prefs k)))
          _s (doseq [sec (or (.-sections reg) [])]
               (doseq [s (or (.-settings sec) [])] (.push knob-prefs (.-pref s))))
          dangling (.filter knob-prefs (fn [pf :- String] :- Bool (not (.includes src (str "\"" pf "\"")))))
          reg-prefs (.sort (Array/from (Set. (.flatMap profiles (fn [p :- Any] :- Any (Object/keys (.-sets p)))))))
          preset-prefs (.sort (Array/from (Set. (preset-pref-names loader))))
          drift (not (= (.join reg-prefs "|") (.join preset-prefs "|")))]
      (cond
        (> (.-length dangling) 0)
        (fail "N" "knobs backed + reversible (knob-not-delete)"
          (str (.-length dangling) " knob(s) reference a pref set nowhere in source")
          (str "a feature was deleted but its knob remains (or a typo) — restore the pref (reversible!) or drop the knob:\n    " (.join dangling "\n    ")))
        drift
        (fail "N" "knobs backed + reversible (knob-not-delete)"
          "registry privacy `sets` prefs != GjoaLoader PRIVACY-PRESETS prefs"
          (str "the picker would set different prefs than the loader applies — sync them.\n    registry: " (.join reg-prefs ", ") "\n    PRESETS:  " (.join preset-prefs ", ")))
        :else
        (pass "N" "knobs backed + reversible (knob-not-delete)"
          (str (.-length knob-prefs) " knobs backed by real prefs; privacy presets (" (.-length preset-prefs) " prefs) in sync with the loader"))))))

;; ── Gate O: no bare beagle/ runtime specifier in shipped gjoa .sys.mjs ─────
;; beagle's value-semantics emit injects `import * as $$bc from 'beagle/core.js'`.
;; Firefox's chrome ES loader cannot resolve a bare specifier; it must be rewritten
;; to resource:///modules/gjoa/beagle/ at compile (tools/prep/overlay.bjs sets
;; BEAGLE_JS_RUNTIME_PREFIX). Today only GjoaLoader compiles with the prefix — a
;; future .bjs-authored .sys.mjs would silently ship the bare import and kill ALL
;; gjoa chrome (the 2026-06-21 break). Fail fast, BEFORE the multi-hour build.
(defn gateO [] :- Any
  (let [gjoaDir (join REPO-ROOT "engine" "browser" "components" "gjoa")]
    (if (not (existsSync gjoaDir))
      (warn "O" "no bare beagle/ import in shipped gjoa .sys.mjs"
        "engine/ not extracted yet — run after `bun run import`")
      (let [dirs (str gjoaDir " " (join REPO-ROOT "engine" "toolkit" "components" "content-classifier"))
            r (sh (str "grep -rlE \"from 'beagle/\" " dirs " --include=*.sys.mjs 2>/dev/null || true") {})
            hits (.trim (or (.-out r) ""))]
        (if (= hits "")
          (pass "O" "no bare beagle/ import in shipped gjoa .sys.mjs"
            "all $$bc runtime imports resolve to resource:///modules/gjoa/beagle/")
          (fail "O" "no bare beagle/ import in shipped gjoa .sys.mjs"
            (str "unresolvable bare `import from 'beagle/...'` in: " (.replaceAll hits "\n" ", "))
            "compile that .bjs with BEAGLE_JS_RUNTIME_PREFIX=resource:///modules/gjoa/beagle/ (tools/prep/overlay.bjs) + vendor the runtime"))))))

;; ── Run + render ──────────────────────────────────────────────────────────
(defn main! [] :- Any
  (console/log (bold "gjoa preflight"))
  (console/log (dim "Mandatory gate before any nix or full-mach build (CLAUDE.md Rule #0)."))
  (console/log "")

  (let [gates [["A" gateA] ["B" gateB] ["C" gateC] ["D" gateD]
               ["E" gateE] ["F" gateF] ["G" gateG] ["H" gateH]
               ["I" gateI] ["J" gateJ] ["K" gateK] ["L" gateL] ["M" gateM]
               ["N" gateN] ["O" gateO]]]
    (doseq [gate gates]
      (let [fn (aget gate 1)]
        (try (fn)
          (catch Error e (fail "?" (.-name fn) "gate threw" (.-message e)))))))

  (doseq [r results]
    (let [mark (cond (.-warned r) (yellow "⚠")
                     (.-passed r) (green "✓")
                     :else (red "✗"))]
      (console/log (str mark "  " (bold (.-id r)) "  " (.-name r)))
      (console/log (str "     " (dim (.-detail r))))
      (when (and (not (.-passed r)) (.-fix r))
        (console/log (str "     " (yellow (str "fix: " (.join (.split (.-fix r) "\n") "\n          "))))))))

  (let [failed (.-length (.filter results (fn [r] (not (.-passed r)))))]
    (console/log "")
    (if (= failed 0)
      (do
        (console/log (str (green (bold "PREFLIGHT GREEN")) (dim (str "  — " (.-length results) "/" (.-length results) " gates passed"))))
        (console/log (dim "Safe to propose a rebuild. Show this output in the proposal."))
        (.exit process 0))
      (do
        (console/log (str (red (bold "PREFLIGHT FAILED")) (dim (str "  — " failed "/" (.-length results) " gates failed"))))
        (console/log (red "Do NOT kick off a build until every gate is green."))
        (.exit process 1)))))

;; The .ts guarded on `import.meta.main`; there is no import.meta in beagle, and
;; Errors abort with exit 1, matching the original `.catch` handler. Guarded so
;; the CLI runs only when invoked directly, never on import.
(when (.-main (js/import-meta))
  (.catch (main!) (fn [e] (console/error e) (.exit process 1))))
