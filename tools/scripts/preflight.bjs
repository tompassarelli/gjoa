#lang beagle/js
;; `gjoa preflight` — the gate that runs before any nix build is allowed.
;;
;; Per CLAUDE.md Rule #0: Claude may not propose a rebuild without
;; showing this script's output. Gates are MECHANICAL. New failure
;; modes get added here, not to a mental checklist that gets skipped.
;;
;; Exits 0 if every gate passes, 1 if any gate fails. Gate F (daemon
;; settings) and Gate G (nix eval) are the two that would have caught
;; the 2026-05-26 failure.
(ns gjoa.tools.scripts.preflight
  (:require [fs :refer [existsSync readFileSync readdirSync]]
            [child_process :refer [execSync]]
            [crypto :refer [createHash]]
            [path :refer [join basename]]
            [gjoa.tools.prep.symbol-resolve :refer [check-contract]]))
(define-mode strict)
(declare-extern [process JSON RegExp Object Set Array] Any)

;; The old .ts used `resolve(import.meta.dir, "..", "..")` to climb from
;; tools/scripts/ to the repo root. There is no import.meta in beagle, and
;; these tools run via `bun run` from the repo root, so cwd IS the repo root.
(def REPO-ROOT :- String (.cwd process))
(def ENGINE-DIR :- String (join REPO-ROOT "engine"))
(def FLAKE :- String (join REPO-ROOT "flake.nix"))
(def PATCHES-DIR :- String (join REPO-ROOT "patches"))
(def GJOA-JSON :- String (join REPO-ROOT "gjoa.json"))
(def LEDGER :- String (join REPO-ROOT "private-docs" "build-logs" "ledger.md"))
(def NIX-RESULT :- String (join REPO-ROOT "result" "bin" "gjoa"))

(def tty :- Any (.-isTTY (.-stdout process)))
(defn c [s :- String code :- String] :- String
  (if tty (str "[" code "m" s "[0m") s))
(defn green [s :- String] :- String (c s "32"))
(defn red [s :- String] :- String (c s "31"))
(defn yellow [s :- String] :- String (c s "33"))
(defn dim [s :- String] :- String (c s "2"))
(defn bold [s :- String] :- String (c s "1"))

;; Accumulated GateResult records (plain JS objects):
;;   {:id :name :passed :warned :detail :fix}
(def results :- Any [])

(defn pass [id :- String name :- String detail :- String] :- Any
  (.push results {:id id :name name :passed true :detail detail}))
(defn fail [id :- String name :- String detail :- String fix :- String] :- Any
  (.push results {:id id :name name :passed false :detail detail :fix fix}))
;; A WARN does not fail the gate (passed: true) but flags a non-fatal,
;; inconclusive result the operator should be aware of — e.g. a nix eval that
;; timed out rather than genuinely failed.
(defn warn [id :- String name :- String detail :- String] :- Any
  (.push results {:id id :name name :passed true :warned true :detail detail}))

(defn sh [cmd :- String opts :- Any] :- Any
  (try
    (let [out (execSync cmd {:encoding "utf8"
                             :timeout (or (.-timeout opts) 30000)
                             :stdio ["ignore" "pipe" "pipe"]})]
      {:ok true :out out})
    (catch Error e
      ;; A timeout (execSync sends SIGTERM and sets code 'ETIMEDOUT') is not a
      ;; real failure of the command — surface it so callers can WARN/skip
      ;; rather than treat it as a hard error.
      (let [timedOut (or (= (.-code e) "ETIMEDOUT") (= (.-signal e) "SIGTERM"))
            stderr (if (.-stderr e) (.toString (.-stderr e)) "")
            stdout (if (.-stdout e) (.toString (.-stdout e)) "")]
        {:ok false
         :timedOut timedOut
         :out (or (str stderr stdout) (.-message e))}))))

;; ── Gate A: patches apply cleanly against fresh source ─────────────────────
(defn gateA! [] :- Any
  (let [cache (str (.-HOME (.-env process)) "/.cache/gjoa/sources")
        gjoa (JSON/parse (readFileSync GJOA-JSON "utf8"))
        tarball (str cache "/firefox-" (.-version (.-firefox gjoa)) ".source.tar.xz")]
    (if (not (existsSync tarball))
      (fail "A" "patches apply clean on fresh source"
        (str "tarball not cached at " tarball)
        "run `bun run download` to populate the cache")
      (let [tmp "/tmp/gjoa-preflight-engine"]
        (sh (str "rm -rf " tmp " && mkdir -p " tmp) {})
        (let [extract (sh (str "tar -xJf " tarball " -C " tmp " --strip-components=1") {:timeout 180000})]
          (if (not (.-ok extract))
            (fail "A" "patches apply clean on fresh source" "tarball extract failed" (.slice (.-out extract) 0 400))
            (do
              (sh (str "cd " tmp " && git init -q && git add -A && git -c user.email=t@t -c user.name=t commit -q -m baseline") {:timeout 60000})
              ;; Apply patches CUMULATIVELY in patch order — each on the result of
              ;; all prior — matching `bun run import`'s real apply order. The old
              ;; per-patch `git apply --check` against the pristine tarball
              ;; false-positives when a later patch depends on lines an EARLIER one
              ;; added (the 0014-on-0013 case): in isolation 0014's context is
              ;; absent, so it "fails", though the real sequenced apply succeeds.
              ;; Here we mutate `tmp` in place (real `git apply`, no --check) so each
              ;; patch sees its predecessors' output. On the FIRST failure we stop —
              ;; subsequent patches build on the failed tree and would cascade.
              (let [patches (.sort (.filter (readdirSync PATCHES-DIR) (fn [p] (.endsWith p ".patch"))))
                    failed []
                    drifted []
                    stopped (atom false)]
                (doseq [p patches]
                  (when (not @stopped)
                    (let [path (join PATCHES-DIR p)
                          ;; Drift WARN is computed BEFORE the real apply, on the
                          ;; current cumulative tree (--dry-run leaves it untouched):
                          ;; GNU patch reports "Hunk #N succeeded at M (offset L lines)"
                          ;; for offset git apply tolerates silently. Largest |offset|.
                          pr (sh (str "cd " tmp " && patch -p1 --dry-run --fuzz=0 --force -i " path " 2>&1 | grep -oiE 'offset -?[0-9]+' | grep -oE '[0-9]+' | sort -rn | head -1") {})
                          off (parseInt (.trim (or (.-out pr) "")) 10)
                          ;; Real cumulative apply (no --check): mutate tmp so the
                          ;; next patch sees this one's added lines.
                          r (sh (str "cd " tmp " && git apply " path) {})]
                      (if (not (.-ok r))
                        (do
                          (.push failed (str p ": " (.trim (or (aget (.split (.-out r) "\n") 0) ""))))
                          (reset! stopped true))
                        (when (> off 0)
                          (.push drifted (str p " (offset " off ")")))))))
                (cond
                  (> (.-length failed) 0)
                  (fail "A" "patches apply clean on fresh source"
                    (str "cumulative apply stopped at the first failing patch (later patches build on it): " (.-length failed) " failed")
                    (str "regenerate the failing patch via `git diff` in a fresh extract WITH all prior patches applied (cumulative order matters):\n    " (.join failed "\n    ")))
                  (> (.-length drifted) 0)
                  (warn "A" "patches apply clean on fresh source"
                    (str (.-length patches) "/" (.-length patches) " apply cumulatively, but " (.-length drifted) " drifting on line-offset (early warning — regenerate before they .rej): " (.join drifted ", ")))
                  :else
                  (pass "A" "patches apply clean on fresh source" (str (.-length patches) "/" (.-length patches) " apply clean cumulatively, no drift")))))))))))

;; ── Gate B: chrome registration uses a known-working pattern ──────────────
(defn gateB [] :- Any
  (let [ours (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "jar.mn")]
    (if (not (existsSync ours))
      (fail "B" "jar.mn pattern matches working example"
        (str ours " missing")
        "restore from git")
      (let [content (readFileSync ours "utf8")
            usesBrowserJar (.test (RegExp. "^browser\\.jar:" "m") content)
            hasContentDecl (.test (RegExp. "^% content\\s+gjoa\\s+%content/gjoa/" "m") content)]
        (cond
          (not usesBrowserJar)
          (fail "B" "jar.mn pattern matches working example"
            "uses `<package>.jar:` syntax — silently no-op in modern Firefox"
            "change first non-comment line to `browser.jar:` (see browser/branding/unofficial/content/jar.mn)")

          (not hasContentDecl)
          (fail "B" "jar.mn pattern matches working example"
            "no `% content gjoa %content/gjoa/` registration line"
            "add `% content gjoa %content/gjoa/` after `browser.jar:`")

          :else
          (pass "B" "jar.mn pattern matches working example" "browser.jar: + % content gjoa %content/gjoa/"))))))

;; ── Gate C: no production-mode TODO/no-op landmines ───────────────────────
(defn gateC [] :- Any
  (let [prodFiles ["src/gjoa/browser/components/gjoa/GjoaLoader.sys.mjs"
                   "src/gjoa/chrome/bjs/security/index.bjs"
                   "src/gjoa/chrome/bjs/drawer/index.bjs"
                   "src/gjoa/chrome/bjs/spaces/index.bjs"
                   "src/gjoa/chrome/bjs/tabs/index.bjs"]
        landmines []
        stub-return (RegExp. "^\\s*return\\s*;?\\s*//\\s*(TODO|FIXME|future)" "i")
        stub-comment (RegExp. "//\\s*(future commit|nothing yet|not yet implemented)" "i")]
    (doseq [f prodFiles]
      (let [path (join REPO-ROOT f)]
        (when (existsSync path)
          (let [lines (.split (readFileSync path "utf8") "\n")]
            ;; Only flag literal "TODO" / "future commit" / "nothing yet" inside
            ;; executable code (not in jsdoc/regular comments that describe
            ;; intent). Heuristic: line ends with `return;` or matches the
            ;; specific dead-stub pattern.
            (.forEach lines
              (fn [l i]
                (when (or (.test stub-return l) (.test stub-comment l))
                  (.push landmines (str f ":" (+ i 1) ": " (.trim l))))))))))
    (if (> (.-length landmines) 0)
      (fail "C" "no production-mode TODO/no-op landmines"
        (str (.-length landmines) " suspicious dead-stub markers in production paths")
        (str "audit + implement or delete each:\n    " (.join landmines "\n    ")))
      (pass "C" "no production-mode TODO/no-op landmines" (str (.-length prodFiles) " prod files scanned, none flagged")))))

;; ── Gate D: dep floors satisfied ──────────────────────────────────────────
(defn gateD [] :- Any
  (let [flakeContent (readFileSync FLAKE "utf8")
        minNssMatch (.match flakeContent (RegExp. "minNssVersion\\s*=\\s*\"([^\"]+)\""))
        minNss (if minNssMatch (aget minNssMatch 1) nil)]
    (if (nil? minNss)
      (pass "D" "dep floors satisfied" "no minNssVersion gate declared")
      (let [probe (sh
                    (str "nix eval --impure --raw --expr '(import (builtins.getFlake \"git+file://" REPO-ROOT "\").inputs.nixpkgs { system = \"x86_64-linux\"; }).nss_latest.version' 2>&1")
                    {:timeout 60000})]
        (if (not (.-ok probe))
          (fail "D" "dep floors satisfied" "could not probe nixpkgs nss_latest.version"
            (str "fix the nix eval error and re-run:\n" (.slice (.-out probe) -300)))
          ;; compareVersions: if nixpkgs >= minNss, overlay short-circuits (good).
          ;; if behind, our overlay activates and Mozilla tarball is fetched.
          (let [nixpkgsNss (.pop (.split (.trim (.-out probe)) "\n"))]
            (pass "D" "dep floors satisfied"
              (str "minNssVersion=" minNss ", nixpkgs nss_latest=" nixpkgsNss " → overlay "
                   ;; Original did a naive JS string `>=`; beagle's `>=` is
                   ;; numeric, so replicate lexicographic comparison via
                   ;; localeCompare (>= 0 means nixpkgsNss >= minNss).
                   (if (>= (.localeCompare (String nixpkgsNss) (String minNss)) 0) "auto-disabled" "ACTIVE (will fetch Mozilla tarball)")))))))))

;; ── Gate E: existing binary status (informational gate) ───────────────────
(defn gateE [] :- Any
  (if (not (existsSync NIX-RESULT))
    (pass "E" "existing binary status" "no result/ symlink (fresh rebuild)")
    (let [omni (join REPO-ROOT "result" "lib" "gjoa" "browser" "omni.ja")]
      (if (not (existsSync omni))
        (pass "E" "existing binary status" "result/ exists but no omni.ja (probably broken — rebuild)")
        (let [r (sh (str "unzip -p " omni " chrome/chrome.manifest 2>/dev/null | grep -c \"^content gjoa\" || true") {})
              count (or (parseInt (.trim (.-out r)) 10) 0)]
          (if (> count 0)
            ;; Binary already has the registration — rebuild only needed if you've
            ;; actually changed something that affects it.
            (pass "E" "existing binary status" (str "current result/ has " count " `content gjoa` line(s); rebuild is REPLACING a working binary"))
            (pass "E" "existing binary status" "current result/ has NO `content gjoa` registration — rebuild needed to restore chrome bundles")))))))

;; ── Gate F: nix daemon will accept flake settings ─────────────────────────
;;
;; Two separate nix permission mechanisms get conflated easily:
;;   * trusted-users  → who can pass --option / --no-sandbox FLAGS at CLI
;;   * sandbox=true   → rejects ANY derivation with `__noChroot=true`
;;                      regardless of who's invoking
;;
;; For `__noChroot = true` to actually take effect, the daemon's
;; `sandbox` setting must be `relaxed` (or `false`). `sandbox = true`
;; rejects it at eval time even for trusted users. This gate caught
;; me on 2026-05-26 — see build-logs postmortem.
(defn gateF [] :- Any
  ;; Strip nix comment lines before matching so we don't false-positive
  ;; on `__noChroot = true` written inside an explanation comment.
  (let [flakeContent (.join
                       (.filter (.split (readFileSync FLAKE "utf8") "\n")
                                (fn [l] (not (.test (RegExp. "^\\s*#") l))))
                       "\n")
        usesNoChroot (.test (RegExp. "__noChroot\\s*=\\s*true") flakeContent)
        usesImpure (.test (RegExp. "__impure\\s*=\\s*true") flakeContent)]
    (if (and (not usesNoChroot) (not usesImpure))
      (pass "F" "nix daemon will accept flake settings" "no privileged settings in flake.nix")
      (let [cfg (sh "nix show-config 2>/dev/null" {:timeout 15000})
            sandboxLine (or (.find (.split (.-out cfg) "\n")
                                   (fn [l] (.test (RegExp. "^sandbox = ") l))) "")
            sandbox (.trim (or (aget (.split sandboxLine "=") 1) ""))]
        (if (and usesNoChroot (= sandbox "true"))
          (fail "F" "nix daemon will accept flake settings"
            "flake uses __noChroot but daemon has sandbox=true → rejected at eval"
            "either:\n      (a) remove __noChroot from flake.nix (Lane 1 edit; lose sccache persistence), or\n      (b) change sandbox = \"relaxed\" in nixos-config nix-settings module + firn rebuild")
          (pass "F" "nix daemon will accept flake settings"
            (str "sandbox=" sandbox " permits __noChroot/__impure")))))))

;; ── Gate G: nix flake evaluates without errors ────────────────────────────
(defn gateG [] :- Any
  (let [r (sh
            (str "nix eval --impure --raw '" REPO-ROOT "#gjoa.outPath' 2>&1")
            {:timeout 120000})]
    (if (not (.-ok r))
      (if (.-timedOut r)
        ;; A dirty git tree defeats nix's eval cache, so eval can be slow without
        ;; being broken. Don't fail the gate on a wall-clock timeout.
        (warn "G" "nix flake evaluates without errors"
          "nix eval timed out — not a real eval failure; re-run with a clean tree or longer timeout")
        (fail "G" "nix flake evaluates without errors"
          "evaluation failed — would have died during build"
          (.join (.slice (.filter (.split (.-out r) "\n")
                                  (fn [l] (.includes (.toLowerCase l) "error"))) 0 5) "\n      ")))
      (pass "G" "nix flake evaluates without errors" (str "derivation resolves to " (.slice (.pop (.split (.trim (.-out r)) "\n")) -50))))))

;; ── Gate H: diff since last working build ─────────────────────────────────
(defn gateH [] :- Any
  (if (not (existsSync LEDGER))
    (pass "H" "diff since last working build" "no ledger yet (first build)")
    (let [ledger (readFileSync LEDGER "utf8")
          lastSuccess (.find (.split ledger "\n")
                             (fn [l] (and (.test (RegExp. "^\\|\\s*\\d{4}-\\d{2}-\\d{2}") l)
                                          (.test (RegExp. "success|works" "i") l)
                                          (not (.test (RegExp. "broken|fail" "i") l)))))]
      (if (nil? lastSuccess)
        (pass "H" "diff since last working build" "no successful build logged yet")
        ;; Find last commit before that date (approximate)
        (let [dateMatch (.match lastSuccess (RegExp. "^\\|\\s*(\\d{4}-\\d{2}-\\d{2})"))
              date (or (if dateMatch (aget dateMatch 1) nil) "")]
          (sh (str "git log --oneline --since='" date "' --until='now' --pretty=format:'%h %s' 2>&1 | head -30") {})
          (let [changed (sh "git diff --name-only HEAD~5..HEAD 2>&1 | head -50" {})
                lines (.filter (.split (.-out changed) "\n") (fn [x] x))]
            (pass "H" "diff since last working build"
              (str (.-length lines) " files changed in recent commits (review for prereqs):\n      "
                   (.join (.slice lines 0 15) "\n      ")
                   (if (> (.-length lines) 15) (str "\n      ... and " (- (.-length lines) 15) " more") "")))))))))

;; ── Gate I: chrome bundle three-way alignment ─────────────────────────────
(defn gateI [] :- Any
  (let [loaderPath (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "GjoaLoader.bjs")
        jarPath (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "jar.mn")
        bakePath (join REPO-ROOT "tools" "prep" "chrome-bake.bjs")]
    (if (not (.every [loaderPath jarPath bakePath] existsSync))
      (fail "I" "chrome bundle three-way alignment" "one of loader/jar/bake missing" "investigate")
      (let [loader (readFileSync loaderPath "utf8")
            jar (readFileSync jarPath "utf8")
            bake (readFileSync bakePath "utf8")
            loaderScripts (.sort (.map (Array/from (.matchAll loader (RegExp. "\"(gjoa-[a-z-]+\\.uc\\.js)\"" "g"))) (fn [m] (aget m 1))))
            jarScripts (.sort (.filter (.map (Array/from (.matchAll jar (RegExp. "scripts/(gjoa-[a-z-]+\\.uc\\.js)" "g"))) (fn [m] (aget m 1)))
                                       (fn [v i a] (= (.indexOf a v) i))))
            bakeScripts (.sort (.map (Array/from (.matchAll bake (RegExp. "\"(gjoa-[a-z-]+\\.uc\\.js)\"" "g"))) (fn [m] (aget m 1))))
            ;; CSS bundles include the bare `gjoa.uc.css` (no hyphen suffix), so the
            ;; style pattern must allow an optional `-...` segment.
            loaderStyles (.sort (.map (Array/from (.matchAll loader (RegExp. "\"(gjoa(?:-[a-z-]+)?\\.uc\\.css)\"" "g"))) (fn [m] (aget m 1))))
            jarStyles (.sort (.filter (.map (Array/from (.matchAll jar (RegExp. "styles/(gjoa(?:-[a-z-]+)?\\.uc\\.css)" "g"))) (fn [m] (aget m 1)))
                                      (fn [v i a] (= (.indexOf a v) i))))
            bakeStyles (.sort (.map (Array/from (.matchAll bake (RegExp. "\"(gjoa(?:-[a-z-]+)?\\.uc\\.css)\"" "g"))) (fn [m] (aget m 1))))
            eq (fn [a :- Any b :- Any]
                 (and (= (.-length a) (.-length b))
                      (.every a (fn [x i] (= x (aget b i))))))]
        (cond
          (or (not (eq loaderScripts jarScripts)) (not (eq loaderScripts bakeScripts)))
          (fail "I" "chrome bundle three-way alignment"
            (str "script lists differ:\n      loader: " (.join loaderScripts ", ") "\n      jar:    " (.join jarScripts ", ") "\n      bake:   " (.join bakeScripts ", "))
            "align all three so they declare the exact same .uc.js filenames")

          (or (not (eq loaderStyles jarStyles)) (not (eq loaderStyles bakeStyles)))
          (fail "I" "chrome bundle three-way alignment"
            (str "style lists differ:\n      loader: " (.join loaderStyles ", ") "\n      jar:    " (.join jarStyles ", ") "\n      bake:   " (.join bakeStyles ", "))
            "align all three so they declare the exact same .uc.css filenames")

          :else
          (pass "I" "chrome bundle three-way alignment"
            (str (.-length loaderScripts) " script + " (.-length loaderStyles) " style bundles agree across loader / jar.mn / chrome-bake.bjs")))))))

;; ── Gate J: vendored scriptlet bundle matches its pinned SHA-256 ──────────
;; scriptlet-resources.json is base64-encoded JS run via evalInSandbox on the
;; privileged side of the content classifier; a swapped/tampered bundle injects
;; attacker JS into pages. Assert it still matches the digest recorded in
;; scriptlet-resources.PROVENANCE.md (security finding F10).
(defn gateJ [] :- Any
  (let [script (join REPO-ROOT "tools" "prep" "verify-scriptlet-resources.sh")]
    (if (not (existsSync script))
      (fail "J" "scriptlet bundle integrity" "verify-scriptlet-resources.sh missing" "restore the F10 verifier")
      (let [r (sh (str "bash " script) {})]
        (if (.-ok r)
          (pass "J" "scriptlet bundle integrity" "scriptlet-resources.json matches the pinned SHA-256")
          (fail "J" "scriptlet bundle integrity"
            (.trim (or (.-out r) "digest mismatch"))
            "if you refreshed the bundle from a pinned uBO commit, update the SHA-256 in verify-scriptlet-resources.sh AND scriptlet-resources.PROVENANCE.md"))))))

;; ── Gate K: engine/ reflects current source (import-currency) ───────────────
;; The compile input is engine/ (gitignored), which only mirrors src/gjoa/ +
;; patches/ + the import tooling AFTER `bun run import`. Every stale-engine
;; catastrophe — e.g. the 2026-06-14 build that compiled a 3-week-old tree, ran
;; green, and silently dropped every recent change — is this gate's failure
;; mode. `import` stamps engine/.gjoa-import-stamp at completion; if any source
;; tree is newer than that stamp, engine/ is stale and must be re-imported.
(def IMPORT-STAMP :- String (join ENGINE-DIR ".gjoa-import-stamp"))
(defn gateK [] :- Any
  (if (not (existsSync IMPORT-STAMP))
    (fail "K" "engine/ reflects current source (import-currency)"
      "no engine/.gjoa-import-stamp — engine/ is unimported (or predates this gate)"
      "run `bun run import` to (re)build engine/ from src/gjoa/ + patches/")
    (let [stamp-r (sh (str "stat -c %Y '" IMPORT-STAMP "'") {})
          newest-r (sh "find src/gjoa patches tools/prep -type f -printf '%T@\\n' 2>/dev/null | sort -rn | head -1" {})
          stamp-out (.trim (or (.-out stamp-r) ""))
          newest-out (.trim (or (.-out newest-r) ""))]
      (if (or (not (.-ok stamp-r)) (not (.-ok newest-r)) (= stamp-out "") (= newest-out ""))
        (warn "K" "engine/ reflects current source (import-currency)"
          "could not determine source/stamp mtimes — skipping (non-fatal)")
        (if (> (parseInt newest-out 10) (parseInt stamp-out 10))
          (fail "K" "engine/ reflects current source (import-currency)"
            "src/gjoa/, patches/, or tools/prep/ changed since the last `bun run import`"
            "run `bun run import` — the build compiles engine/, not src/, so un-imported edits silently vanish from the binary")
          (pass "K" "engine/ reflects current source (import-currency)"
            "no src/patches/tooling edits since the last import"))))))

;; ── Gate L: surface contracts (declared upstream deps still resolve) ────────
;; A patch/overlay DEPENDS ON upstream symbols it references but does not patch
;; (a Rust path, a generated style-struct accessor, a JS object property). git
;; apply (Gate A) is blind to these — they're added tokens, not context — so a
;; MOVE/REMOVAL passes apply and dies 26 min into the compile (ComputedValueFlags
;; module move; background_image field removal) or ships a silent no-op
;; (FF152 deleting AboutNewTab.newTabURL). A `# depends-on:` / `;; @gjoa-depends-on`
;; block declares those anchors; Gate L resolves each against engine/, RED before
;; the build if one vanished. Design: private-docs/research-fork-currency-gate-l.md.
(def OVERLAY-FILES :- Any
  [(join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "GjoaLoader.bjs")])
;; Count raw `# depends-on` bullets — every `- <kind> ...` line whose kind carries a
;; dep marker. DECLARED count; check-contract returns the EVALUATED count. Any gap =
;; the parser silently dropped a declared dep (the cpp-symbol/cpp-member skew) — fail-closed.
(def DEP-BULLET-RE :- Any (RegExp. "(?:#|;;)\\s*-\\s*((?:rust|cpp|webidl|js)-[a-z-]+)\\s+\\S" "gm"))
(defn count-declared-deps [text :- String] :- Number
  (let [m (.match text DEP-BULLET-RE)]
    (if m (.-length m) 0)))
(defn gateL [] :- Any
  (let [patch-files (.map (.filter (readdirSync PATCHES-DIR) (fn [p :- String] :- Bool (.endsWith p ".patch")))
                          (fn [p :- String] :- String (join PATCHES-DIR p)))
        files (.concat patch-files (.filter OVERLAY-FILES (fn [f :- String] :- Bool (existsSync f))))
        not-found []
        ambiguous []
        unsupported []
        dropped []
        resolved []]
    (doseq [f files]
      (let [text (readFileSync f "utf8")
            results (check-contract text)
            declared (count-declared-deps text)]
        ;; reconciliation: every declared `# depends-on` bullet MUST produce an evaluated
        ;; result; a shortfall = the parser silently dropped a dep (unknown/typo'd kind).
        (let [delta (- declared (.-length results))]
          (if (> delta 0)
            (.push dropped (str (basename f) ": " delta " declared depends-on bullet(s) parsed to nothing (unknown/typo'd kind — vocabulary drift)"))))
        (doseq [r results]
          (cond
            (= (.-verdict r) "not-found")
            (.push not-found (str (basename f) ": " (.-kind r) " `" (.-symbol r) "` — " (.-detail r)))
            (= (.-verdict r) "unsupported")
            (.push unsupported (str (basename f) ": " (.-kind r) " `" (.-symbol r) "` — " (.-detail r)))
            (= (.-verdict r) "ambiguous")
            (.push ambiguous (str (basename f) ": " (.-symbol r)))
            :else (.push resolved (.-symbol r))))))
    (cond
      ;; FAIL-CLOSED: a dep that moved (not-found), one the resolver can't evaluate
      ;; (unsupported kind), or one the parser dropped (declared>evaluated) blocks the build.
      ;; Green Gate L now means "every DECLARED anchor RESOLVED", not "the few we parsed did".
      (> (+ (+ (.-length not-found) (.-length unsupported)) (.-length dropped)) 0)
      (fail "L" "surface contracts (declared upstream deps resolve)"
        (str (+ (+ (.-length not-found) (.-length unsupported)) (.-length dropped)) " declared dependency(ies) unresolved or unevaluated (" (.-length resolved) " resolved)")
        (str "regenerate the patch/overlay against current upstream, or fix the dep declaration:\n    "
             (.join (.concat (.concat not-found unsupported) dropped) "\n    ")))
      (> (.-length ambiguous) 0)
      (warn "L" "surface contracts (declared upstream deps resolve)"
        (str (.-length resolved) " resolved, " (.-length ambiguous) " ambiguous (cfg/glob/no-objdir — can't prove): " (.join ambiguous ", ")))
      :else
      (pass "L" "surface contracts (declared upstream deps resolve)"
        (str (.-length resolved) " declared upstream dependencies resolve")))))

;; ── Gate M: beagle compiler pinned (beagle-currency) ───────────────────────
;; gjoa compiles against a DEDICATED beagle worktree at ~/code/beagle-pin (NOT the
;; shared ../beagle checkout — detaching that tree is forbidden, it's shared across
;; concurrent agents). The worktree is parked permanently at the pinned ref so the
;; compiler is deterministic and no other agent's branch switch can change gjoa's
;; build. configs/beagle.ref records the expected ref. This is a HARD FAIL on drift:
;; the build MUST compile chrome against the pinned ref (the emit/runtime contract is
;; ref-specific). A warn here is what let 4 serial breaks ship — the drift was
;; visible but nothing forced the build to honor the pin. Now it does.
(def BEAGLE-REF-FILE :- String (join REPO-ROOT "configs" "beagle.ref"))
;; The dedicated pinned worktree gjoa compiles against. $HOME-relative so it
;; resolves on any machine, never a literal /home/<user> path.
(def BEAGLE-PIN-DIR :- String (join (.-HOME (.-env process)) "code" "beagle-pin"))
(defn gate-m-fix [pinned :- String] :- String
  (str "re-point the DEDICATED pin worktree (NEVER `cd ../beagle && git checkout` — that detaches the SHARED tree):\n"
       "      create: `git -C ../beagle worktree add " BEAGLE-PIN-DIR " " (.slice pinned 0 12) "`\n"
       "      re-point: `git -C " BEAGLE-PIN-DIR " checkout " (.slice pinned 0 12) "`\n"
       "    — OR bump deliberately, ATOMICALLY: bump configs/beagle.ref → re-point the worktree → "
       "`bun run import` (re-vendors core.js) → `bun run sovereignty:manifest` (recompile chrome) → smoke-test → commit together."))
(defn gateM [] :- Any
  (if (not (existsSync BEAGLE-REF-FILE))
    (fail "M" "beagle compiler pinned (beagle-currency)"
      "no configs/beagle.ref — gjoa builds against an unpinned beagle worktree (non-reproducible)"
      "create configs/beagle.ref with the intended beagle commit, then add the pin worktree at it")
    (let [lines (.split (readFileSync BEAGLE-REF-FILE "utf8") "\n")
          pinned (.trim (or (.find lines (fn [l :- String] :- Bool
                                           (and (> (.-length (.trim l)) 0)
                                                (not (.startsWith (.trim l) "#"))))) ""))
          r (sh (str "git -C " BEAGLE-PIN-DIR " rev-parse HEAD") {})
          actual (.trim (or (.-out r) ""))]
      (cond
        (= pinned "") (fail "M" "beagle compiler pinned (beagle-currency)"
                        "configs/beagle.ref has no ref line"
                        "add the intended beagle commit hash to configs/beagle.ref")
        (or (not (.-ok r)) (= actual "")) (fail "M" "beagle compiler pinned (beagle-currency)"
                                            (str "could not read " BEAGLE-PIN-DIR " HEAD — the pin worktree is missing")
                                            (gate-m-fix pinned))
        (.startsWith actual pinned) (pass "M" "beagle compiler pinned (beagle-currency)"
                                      (str BEAGLE-PIN-DIR " at pinned ref " (.slice pinned 0 12)))
        :else (fail "M" "beagle compiler pinned (beagle-currency)"
                (str BEAGLE-PIN-DIR " HEAD " (.slice actual 0 12) " != pinned " (.slice pinned 0 12)
                     " — chrome would be compiled against a DIFFERENT beagle than pinned (emit/$$bc-runtime drift)")
                (gate-m-fix pinned))))))

;; ── Gate N: knobs backed + reversible (knob-not-delete) ────────────────────
;; Every knob about:gjoa exposes (settings/registry.json) must be backed by a pref
;; actually SET in source. A dangling knob — whose feature was deleted but whose
;; toggle remains — is a no-op that lies to the user; this gate makes that deletion
;; impossible to ship silently (restore the pref, reversibly, or remove the knob).
;; Also asserts the registry privacy-profile `sets` prefs == GjoaLoader's
;; PRIVACY-PRESETS prefs, so the picker sets exactly what the loader applies.
(def REGISTRY-FILE :- String
  (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "content" "settings" "registry.json"))
(def LOADER-FILE :- String
  (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "GjoaLoader.bjs"))
(def PREF-DIR :- String (join REPO-ROOT "src" "gjoa" "defaults" "pref"))

(defn quoted-strings [s :- String] :- Any
  (let [m (.match s (RegExp. "\"[^\"]+\"" "g"))]
    (if m (.map m (fn [q :- String] :- String (.slice q 1 -1))) [])))

(defn preset-pref-names [loader :- String] :- Any
  ;; pref-names referenced in the PRIVACY-PRESETS def: quoted strings containing a
  ;; "." (pref names have dots; "bool"/"int" and the profile-id keys don't).
  (let [start (.indexOf loader "(def PRIVACY-PRESETS")
        end (.indexOf loader "(defn apply-privacy-profile!")
        block (if (and (>= start 0) (> end start)) (.slice loader start end) "")]
    (.filter (quoted-strings block) (fn [q :- String] :- Bool (.includes q ".")))))

(defn gateN [] :- Any
  (if (not (and (existsSync REGISTRY-FILE) (existsSync LOADER-FILE) (existsSync PREF-DIR)))
    (warn "N" "knobs backed + reversible (knob-not-delete)"
      "no about:gjoa registry/loader/prefs — skipping")
    (let [reg (JSON/parse (readFileSync REGISTRY-FILE "utf8"))
          loader (readFileSync LOADER-FILE "utf8")
          pref-src (.join (.map (.filter (readdirSync PREF-DIR) (fn [f :- String] :- Bool (.endsWith f ".bjs")))
                                (fn [f :- String] :- String (readFileSync (join PREF-DIR f) "utf8"))) "\n")
          src (str pref-src "\n" loader)
          pv (.-privacy reg)
          sel (and pv (.-selector pv))
          profiles (or (and sel (.-profiles sel)) [])
          knob-prefs []
          _g (doseq [g (or (and pv (.-granular pv)) [])] (.push knob-prefs (.-pref g)))
          _ps (doseq [p profiles] (doseq [k (Object/keys (.-sets p))] (.push knob-prefs k)))
          _s (doseq [sec (or (.-sections reg) [])]
               (doseq [s (or (.-settings sec) [])] (.push knob-prefs (.-pref s)))
               ;; sections may group settings under named subsections (e.g.
               ;; "Dark mode & color" -> Dark mode / Theme); walk those too so
               ;; every nested knob is still backing-checked.
               (doseq [sub (or (.-subsections sec) [])]
                 (doseq [s (or (.-settings sub) [])] (.push knob-prefs (.-pref s)))))
          dangling (.filter knob-prefs (fn [pf :- String] :- Bool (not (.includes src (str "\"" pf "\"")))))
          reg-prefs (.sort (Array/from (Set. (.flatMap profiles (fn [p :- Any] :- Any (Object/keys (.-sets p)))))))
          preset-prefs (.sort (Array/from (Set. (preset-pref-names loader))))
          drift (not (= (.join reg-prefs "|") (.join preset-prefs "|")))]
      (cond
        (> (.-length dangling) 0)
        (fail "N" "knobs backed + reversible (knob-not-delete)"
          (str (.-length dangling) " knob(s) reference a pref set nowhere in source")
          (str "a feature was deleted but its knob remains (or a typo) — restore the pref (reversible!) or drop the knob:\n    " (.join dangling "\n    ")))
        drift
        (fail "N" "knobs backed + reversible (knob-not-delete)"
          "registry privacy `sets` prefs != GjoaLoader PRIVACY-PRESETS prefs"
          (str "the picker would set different prefs than the loader applies — sync them.\n    registry: " (.join reg-prefs ", ") "\n    PRESETS:  " (.join preset-prefs ", ")))
        :else
        (pass "N" "knobs backed + reversible (knob-not-delete)"
          (str (.-length knob-prefs) " knobs backed by real prefs; privacy presets (" (.-length preset-prefs) " prefs) in sync with the loader"))))))

;; ── Gate O: no bare beagle/ runtime specifier in shipped gjoa .sys.mjs ─────
;; beagle's value-semantics emit injects `import * as $$bc from 'beagle/core.js'`.
;; Firefox's chrome ES loader cannot resolve a bare specifier; it must be rewritten
;; to resource:///modules/gjoa/beagle/ at compile (tools/prep/overlay.bjs sets
;; BEAGLE_JS_RUNTIME_PREFIX). Today only GjoaLoader compiles with the prefix — a
;; future .bjs-authored .sys.mjs would silently ship the bare import and kill ALL
;; gjoa chrome (the 2026-06-21 break). Fail fast, BEFORE the multi-hour build.
(defn gateO [] :- Any
  (let [gjoaDir (join REPO-ROOT "engine" "browser" "components" "gjoa")]
    (if (not (existsSync gjoaDir))
      (warn "O" "no bare beagle/ import in shipped gjoa .sys.mjs"
        "engine/ not extracted yet — run after `bun run import`")
      (let [dirs (str gjoaDir " " (join REPO-ROOT "engine" "toolkit" "components" "content-classifier"))
            r (sh (str "grep -rlE \"from 'beagle/\" " dirs " --include=*.sys.mjs 2>/dev/null || true") {})
            hits (.trim (or (.-out r) ""))]
        (if (= hits "")
          (pass "O" "no bare beagle/ import in shipped gjoa .sys.mjs"
            "all $$bc runtime imports resolve to resource:///modules/gjoa/beagle/")
          (fail "O" "no bare beagle/ import in shipped gjoa .sys.mjs"
            (str "unresolvable bare `import from 'beagle/...'` in: " (.replaceAll hits "\n" ", "))
            "compile that .bjs with BEAGLE_JS_RUNTIME_PREFIX=resource:///modules/gjoa/beagle/ (tools/prep/overlay.bjs) + vendor the runtime"))))))

;; ── Gate P: patch-hash drift (#104a) ───────────────────────────────────────
;; configs/patch-hashes.json records the EXPECTED SHA-256 of every patches/*.patch
;; (a tracked, reviewed trust anchor). Gate P recomputes each patch's digest and
;; HARD-FAILS on any mismatch, any patch missing from the manifest, or any manifest
;; entry whose patch was deleted — so a patch can't change (or appear/vanish) without
;; a corresponding, review-gated manifest update. This is the per-patch, drift-gating
;; record; DISTINCT from the aggregate `gjoa.build.engine-patch-hash` that
;; tools/prep/fingerprint.bjs bakes into the binary for provenance.
(def PATCH-HASHES-FILE :- String (join REPO-ROOT "configs" "patch-hashes.json"))
(defn sha256-file [path :- String] :- String
  (.digest (.update (createHash "sha256") (readFileSync path)) "hex"))
(defn gateP [] :- Any
  (if (not (existsSync PATCH-HASHES-FILE))
    (fail "P" "patch hashes match recorded manifest (#104a)"
      "no configs/patch-hashes.json — patch drift is unguarded"
      "create configs/patch-hashes.json with {\"algorithm\":\"sha256\",\"patches\":{<file>:<sha256>}} for every patches/*.patch")
    (let [manifest (JSON/parse (readFileSync PATCH-HASHES-FILE "utf8"))
          recorded (or (.-patches manifest) {})
          patches (.sort (.filter (readdirSync PATCHES-DIR) (fn [p :- String] :- Bool (.endsWith p ".patch"))))
          mismatched []
          missing []]
      ;; current patches whose hash drifted or that aren't recorded at all
      (doseq [p patches]
        (let [actual (sha256-file (join PATCHES-DIR p))
              expected (aget recorded p)]
          (cond
            (nil? expected) (.push missing (str p " (no entry in manifest)"))
            (not (= actual expected))
            (.push mismatched (str p ": recorded " (.slice expected 0 12) "… actual " (.slice actual 0 12) "…")))))
      ;; manifest entries whose patch was deleted (stale record)
      (let [stale (.filter (Object/keys recorded) (fn [k :- String] :- Bool (= (.indexOf patches k) -1)))]
        (cond
          (or (> (.-length mismatched) 0) (> (.-length missing) 0) (> (.-length stale) 0))
          (fail "P" "patch hashes match recorded manifest (#104a)"
            (str (.-length mismatched) " drifted, " (.-length missing) " unrecorded, " (.-length stale) " stale entry(ies)")
            (str "a patch changed without updating its recorded hash — review the diff, then regenerate the manifest:\n"
                 "      cd patches && for f in $(ls *.patch | sort); do echo \"$f $(sha256sum \"$f\" | cut -d' ' -f1)\"; done\n"
                 "    drift:      " (.join mismatched "\n                ") "\n"
                 "    unrecorded: " (.join missing ", ") "\n"
                 "    stale:      " (.join stale ", ")))
          :else
          (pass "P" "patch hashes match recorded manifest (#104a)"
            (str (.-length patches) "/" (.-length patches) " patch hashes match configs/patch-hashes.json")))))))

;; ── Gate Q: $$bc runtime export-closure (emit ↔ vendored core.js) ──────────
;; gjoa's chrome compiles against the pinned beagle (configs/beagle.ref) and
;; references the value-semantics runtime ($$bc) two ways:
;;   (a) namespace property access `$$bc.X`        — in the .uc.js bundles
;;       (window.$$bc is the ESM namespace import set up by GjoaLoader), and
;;   (b) ESM NAMED imports `import { X as $$bc$… } from '…/beagle/core.js'`
;;       — in the .sys.mjs (GjoaLoader). THIS form is what broke 2026-06-21:
;;       the pin's bin/beagle-build emitted `import { equivV … }` but the pin's
;;       core.js exports only `equiv` — a named-import of a missing export is a
;;       module-load SyntaxError that kills GjoaLoader.sys.mjs at import and the
;;       whole gjoa chrome never initializes. A gate that greps only `$$bc.X`
;;       would MISS this — so we parse BOTH forms.
;; Assertion: for every emitted gjoa chrome file, the set of beagle-runtime
;; symbols it references must be a SUBSET of the vendored core.js export surface.
;; Any `file: symbol` not exported is a hard fail — the same skew the shim fixes.
(def VENDORED-CORE :- String
  (join ENGINE-DIR "browser" "components" "gjoa" "beagle" "core.js"))
(def GJOA-LOADER-MJS :- String
  (join ENGINE-DIR "browser" "components" "gjoa" "GjoaLoader.sys.mjs"))
;; CANONICAL bundle output: `bun run chrome:dist` always (re)writes dist/chrome/JS.
;; This is the single source of truth the dev loader AND chrome:install/bake both
;; consume — and it's fresh after every Lane-1 cycle, unlike the obj-* deploy dir
;; (a stale MACH-build artifact between builds). Scan this FIRST.
(def GJOA-BUNDLE-DIST-DIR :- String
  (join REPO-ROOT "dist" "chrome" "JS"))
;; obj-* deploy dir — only fresh right after a mach build; a FALLBACK, never preferred
;; (preferring it scanned last-build's stale bundles → false Gate-Q failures).
(def GJOA-BUNDLE-DIR :- String
  (join ENGINE-DIR "obj-x86_64-pc-linux-gnu" "dist" "bin" "browser" "chrome" "browser" "content" "gjoa" "scripts"))
;; engine/ src copy — final fallback when neither built output exists.
(def GJOA-BUNDLE-SRC-DIR :- String
  (join ENGINE-DIR "browser" "components" "gjoa" "content" "scripts"))

;; export surface of the vendored core.js: `export function NAME`,
;; `export const NAME`, and re-exports `export { A as B }` (B is the exported
;; name) / `export { A }` (A is exported). The compat shim's
;; `export { equiv as equivV };` lands `equivV` here.
(defn core-export-surface [src :- String] :- Any
  (let [surface (Set.)]
    (doseq [m (Array/from (.matchAll src (RegExp. "export\\s+(?:function|const)\\s+([A-Za-z_$][A-Za-z0-9_$]*)" "g")))]
      (.add surface (aget m 1)))
    ;; `export { a as b, c }` → exported names are b and c.
    (doseq [m (Array/from (.matchAll src (RegExp. "export\\s*\\{([^}]*)\\}" "g")))]
      (doseq [clause (.split (aget m 1) ",")]
        (let [t (.trim clause)]
          (when (> (.-length t) 0)
            (let [asM (.match t (RegExp. "\\bas\\s+([A-Za-z_$][A-Za-z0-9_$]*)\\s*$"))]
              (.add surface (if asM (aget asM 1) (.trim (aget (.split t (RegExp. "\\s")) 0)))))))))
    surface))

;; beagle-runtime EXPORT symbols a chrome file references for CLOSURE checking
;; (each must exist in core.js's export surface), two forms:
;;   (a) `$$bc.X` namespace access — in .uc.js bundles (window.$$bc is the
;;       namespace; the bundler's per-file `const $$bc$L = $$bc.X;` preludes also
;;       land here, so the closure-relevant X is the real export), and
;;   (b) `import { X as … } from '<…>/beagle/core.js'` named-import (.sys.mjs).
;; NOTE: the bare named-import LOCAL `$$bc$L` (9d791ed .uc.js emit) is NOT a
;; closure symbol — its suffix L is beagle's LOCAL name, not an export (e.g.
;; `$$bc$equiv` ← export `equivV`, NOT `equiv`). Its real export reaches closure
;; via the prelude's `$$bc.X` (form a); whether that prelude EXISTS at all is the
;; separate binding-presence assertion in gateQ. (Scanning `$$bc$L` suffixes for
;; closure would mis-check a local against the export set — the wrong invariant.)
(defn referenced-runtime-symbols [src :- String] :- Any
  (let [refs (Set.)]
    ;; (a) namespace property access
    (doseq [m (Array/from (.matchAll src (RegExp. "\\$\\$bc\\.([A-Za-z_$][A-Za-z0-9_$]*)" "g")))]
      (.add refs (aget m 1)))
    ;; (b) ESM named imports from any `…/beagle/core.js` specifier. Capture the
    ;; brace clause, then each `X` / `X as Y` (imported name X must be exported).
    (doseq [m (Array/from (.matchAll src (RegExp. "import\\s*\\{([^}]*)\\}\\s*from\\s*['\"][^'\"]*beagle/core\\.js['\"]" "g")))]
      (doseq [clause (.split (aget m 1) ",")]
        (let [t (.trim clause)]
          (when (> (.-length t) 0)
            (.add refs (.trim (aget (.split t (RegExp. "\\s")) 0)))))))
    refs))

(defn gateQ [] :- Any
  (if (not (existsSync VENDORED-CORE))
    (warn "Q" "$$bc runtime export-closure (emit ↔ core.js)"
      "engine/.../beagle/core.js not vendored yet — run after `bun run import`")
    (let [surface (core-export-surface (readFileSync VENDORED-CORE "utf8"))
          ;; Scan the loader + every deployed bundle (or its engine/ source
          ;; fallback when the obj-* deploy dir isn't populated).
          bundle-dir (cond
                       (existsSync GJOA-BUNDLE-DIST-DIR) GJOA-BUNDLE-DIST-DIR
                       (existsSync GJOA-BUNDLE-DIR) GJOA-BUNDLE-DIR
                       :else GJOA-BUNDLE-SRC-DIR)
          bundle-files (if (existsSync bundle-dir)
                         (.map (.filter (readdirSync bundle-dir) (fn [f :- String] :- Bool (.endsWith f ".uc.js")))
                               (fn [f :- String] :- String (join bundle-dir f)))
                         [])
          ;; Any other emitted gjoa .sys.mjs that imports the beagle runtime.
          gjoa-dir (join ENGINE-DIR "browser" "components" "gjoa")
          mjs-files (if (existsSync gjoa-dir)
                      (.map (.filter (readdirSync gjoa-dir)
                                     (fn [f :- String] :- Bool
                                       (and (.endsWith f ".sys.mjs")
                                            (.includes (readFileSync (join gjoa-dir f) "utf8") "beagle/core.js"))))
                            (fn [f :- String] :- String (join gjoa-dir f)))
                      [])
          ;; GjoaLoader is always in mjs-files if present (it imports core.js),
          ;; but include it explicitly so a non-importing-but-$$bc file is caught too.
          files (.filter (Array/from (Set. (.concat [GJOA-LOADER-MJS] bundle-files mjs-files)))
                         (fn [f :- String] :- Bool (existsSync f)))
          offenders []]
      (doseq [f files]
        (let [refs (referenced-runtime-symbols (readFileSync f "utf8"))]
          (doseq [sym (Array/from refs)]
            (when (not (.has surface sym))
              (.push offenders (str (basename f) ": " sym))))))
      ;; binding-presence: in a .uc.js bundle the value-runtime locals `$$bc$L`
      ;; are bare refs that resolve ONLY because the bundler (build.bjs
      ;; rewrite-core-import) emits a per-file `const $$bc$L = $$bc.<export>;`
      ;; prelude from beagle's stripped core.js import. Export-closure (above)
      ;; cannot catch a MISSING prelude — a referenced `$$bc$L` with no decl just
      ;; ReferenceErrors at load (the 2026-06-22 break). So assert every local a
      ;; bundle references is also DECLARED in that same bundle.
      (doseq [f bundle-files]
        (when (existsSync f)
          (let [src (readFileSync f "utf8")
                declared (Set.)
                referenced (Set.)]
            ;; declared: LHS of each `const $$bc$L = $$bc.…` prelude binding.
            (doseq [m (Array/from (.matchAll src (RegExp. "\\$\\$bc\\$([A-Za-z_$][A-Za-z0-9_$]*)\\s*=\\s*\\$\\$bc\\." "g")))]
              (.add declared (aget m 1)))
            ;; referenced: every `$$bc$L` occurrence (incl. the decl LHS, which is
            ;; thus self-satisfied — only body-only refs can be orphans).
            (doseq [m (Array/from (.matchAll src (RegExp. "\\$\\$bc\\$([A-Za-z_$][A-Za-z0-9_$]*)" "g")))]
              (.add referenced (aget m 1)))
            (doseq [sym (Array/from referenced)]
              (when (not (.has declared sym))
                (.push offenders
                  (str (basename f) ": $$bc$" sym " referenced but unbound — no `const $$bc$" sym " = $$bc.<export>` prelude (bundler rewrite-core-import missing/regressed)")))))))
      (if (> (.-length offenders) 0)
        (fail "Q" "$$bc runtime export-closure (emit ↔ core.js)"
          (str (.-length offenders) " emitted runtime reference(s) not exported by the vendored core.js")
          (str "the beagle emit references a $$bc symbol the vendored core.js doesn't export "
               "(ESM named-import of a missing export = module-load SyntaxError → gjoa chrome never initializes). "
               "reconcile via the compat re-export in tools/prep/overlay.bjs (vendor-core-js!) or bump configs/beagle.ref to a beagle whose core.js exports it:\n    "
               (.join offenders "\n    ")))
        (pass "Q" "$$bc runtime export-closure (emit ↔ core.js)"
          (str (.-length files) " emitted file(s) scanned; all $$bc refs (namespace + named-import) ⊆ "
               (.-size surface) " core.js exports"))))))

;; ── Gate R: security mitigations intact (#121) ──────────────────────────────
;; configs/security-mitigations.json is a per-mitigation regression manifest: for
;; each shipped security mitigation it records the source `file` + `mustMatch`
;; regexes that must still hit it (the belt/cap/pref is still PRESENT), and — for a
;; regex-validator mitigation like the cosmetic selector filter — an `extractRegex`
;; plus `mustReject`/`mustAccept` selector cases. A mitigation can silently ROT (the
;; belt deleted, the `*/` guard dropped, the default-off pref flipped) without any
;; build error; Gate R makes that deletion RED here, BEFORE a 2–3h compile. We cannot
;; IMPORT GjoaCosmeticChild.sys.mjs (it `extends JSWindowActorChild`, undefined off a
;; chrome window), so we EXTRACT the UNSAFE_SELECTOR regex literal from the source
;; text and re-test it directly. Design twin of Gate P (patch-hash drift): a tracked
;; manifest is the trust anchor, the gate enforces it.
(def MITIGATIONS-FILE :- String (join REPO-ROOT "configs" "security-mitigations.json"))
(defn gateR [] :- Any
  (if (not (existsSync MITIGATIONS-FILE))
    (fail "R" "security mitigations intact (#121)"
      "no configs/security-mitigations.json — shipped mitigations are unguarded against silent rot"
      "create configs/security-mitigations.json with {\"mitigations\":{<id>:{file,mustMatch,[extractRegex,mustReject,mustAccept]}}}")
    (let [manifest (JSON/parse (readFileSync MITIGATIONS-FILE "utf8"))
          mits (or (.-mitigations manifest) {})
          ids (Object/keys mits)
          problems []]
      (doseq [id ids]
        (let [e (aget mits id)
              rel (.-file e)
              path (join REPO-ROOT rel)]
          (if (not (existsSync path))
            (.push problems (str id ": source file " rel " is GONE (mitigation deleted?)"))
            (let [src (readFileSync path "utf8")]
              ;; (1) every mustMatch regex must still hit the source.
              (doseq [rx (or (.-mustMatch e) [])]
                (when (not (.test (RegExp. rx "m") src))
                  (.push problems (str id ": mustMatch /" rx "/ no longer present in " rel " — the mitigation was edited/removed"))))
              ;; (2) extract the validator regex literal from source text + re-test
              ;; it against the reject/accept corpus (cannot import the actor).
              (let [ex (.-extractRegex e)]
                (when ex
                  (let [m (.match src (RegExp. (.-from ex)))]
                    (if (not (and m (aget m 1)))
                      (.push problems (str id ": extractRegex /" (.-from ex) "/ found no regex literal in " rel))
                      (let [lit (aget m 1)
                            ;; strip the surrounding slashes (and any flags) → the regex body.
                            body-m (.match lit (RegExp. "^/(.*)/([a-z]*)$"))
                            body (if body-m (aget body-m 1) lit)
                            flags (if body-m (aget body-m 2) "")
                            re :- Any (try (RegExp. body flags) (catch Error _e nil))]
                        (if (not re)
                          (.push problems (str id ": extracted literal `" lit "` is not a constructable RegExp"))
                          (do
                            ;; mustReject: each MUST be rejected (regex matches → safeSelector drops it).
                            (doseq [s (or (.-mustReject e) [])]
                              (when (not (.test re s))
                                (.push problems (str id ": mustReject " (JSON/stringify s) " is NOT rejected by the current " (.-name ex) " — breakout no longer blocked"))))
                            ;; mustAccept: each MUST be accepted (regex must NOT match).
                            (doseq [s (or (.-mustAccept e) [])]
                              (when (.test re s)
                                (.push problems (str id ": mustAccept " (JSON/stringify s) " is now WRONGLY rejected by " (.-name ex) " — over-broad, real rules dropped")))))))))))))))
      (if (> (.-length problems) 0)
        (fail "R" "security mitigations intact (#121)"
          (str (.-length problems) " mitigation check(s) failed across " (.-length ids) " entry(ies)")
          (str "a shipped security mitigation rotted — restore it, or (if intentionally changed) update configs/security-mitigations.json:\n    "
               (.join problems "\n    ")))
        (pass "R" "security mitigations intact (#121)"
          (str (.-length ids) " mitigation(s) intact (mustMatch + extracted-regex reject/accept all hold)"))))))

;; ── Gate S: security-critical patches persist (#120) ────────────────────────
;; A patch whose header carries a `# security:` block mitigates a recorded finding;
;; it must NOT silently stop applying (the vuln re-opens) and every upstream anchor
;; it `depends-on` must still resolve. Unlike Gate A/L (warn/drift), here a non-apply
;; is a HARD fail and an unresolved anchor is fail-CLOSED — security regressions never
;; ship as a yellow warning. Reuses Gate A's cumulative-apply probe + Gate L's
;; check-contract. VACUOUSLY GREEN today: zero patches carry a `security:` block.
(defn patch-security-block? [text :- String] :- Bool
  ;; `# security:` (with optional indent) anywhere in the header region.
  (.test (RegExp. "^#\\s*security:\\s*$" "m") text))
(defn gateS! [] :- Any
  (let [patches (.sort (.filter (readdirSync PATCHES-DIR) (fn [p :- String] :- Bool (.endsWith p ".patch"))))
        sec-patches (.filter patches (fn [p :- String] :- Bool
                                       (patch-security-block? (readFileSync (join PATCHES-DIR p) "utf8"))))]
    (if (= (.-length sec-patches) 0)
      (pass "S" "security-critical patches persist (#120)"
        "no `security:`-tagged patches (vacuously green; gate arms automatically when one is added)")
      ;; Build a fresh extract once, apply patches cumulatively in order; record the
      ;; apply result of each security-tagged patch, and resolve its declared anchors.
      (let [cache (str (.-HOME (.-env process)) "/.cache/gjoa/sources")
            gjoa (JSON/parse (readFileSync GJOA-JSON "utf8"))
            tarball (str cache "/firefox-" (.-version (.-firefox gjoa)) ".source.tar.xz")]
        (if (not (existsSync tarball))
          (fail "S" "security-critical patches persist (#120)"
            (str (.-length sec-patches) " security-tagged patch(es) but the source tarball is not cached at " tarball " — cannot prove they apply (fail-closed)")
            "run `bun run download` to populate the cache, then re-run preflight")
          (let [tmp "/tmp/gjoa-preflight-sec-engine"]
            (sh (str "rm -rf " tmp " && mkdir -p " tmp) {})
            (let [extract (sh (str "tar -xJf " tarball " -C " tmp " --strip-components=1") {:timeout 180000})]
              (if (not (.-ok extract))
                (fail "S" "security-critical patches persist (#120)" "tarball extract failed (fail-closed)" (.slice (.-out extract) 0 400))
                (do
                  (sh (str "cd " tmp " && git init -q && git add -A && git -c user.email=t@t -c user.name=t commit -q -m baseline") {:timeout 60000})
                  (let [failed []
                        unresolved []
                        stopped (atom false)]
                    (doseq [p patches]
                      (when (not @stopped)
                        (let [ppath (join PATCHES-DIR p)
                              is-sec (.includes sec-patches p)
                              r (sh (str "cd " tmp " && git apply " ppath) {})]
                          (when (not (.-ok r))
                            (reset! stopped true)
                            ;; only a SECURITY patch failing to apply is itself a security
                            ;; regression; a non-security patch breaking the chain ALSO blocks
                            ;; downstream security patches from being proven, so it is recorded
                            ;; as a fail-closed blocker.
                            (.push failed (str p (if is-sec " (SECURITY)" " (blocks downstream security patches)") ": "
                                               (.trim (or (aget (.split (.-out r) "\n") 0) ""))))))))
                    ;; resolve declared anchors of each security-tagged patch (fail-closed).
                    (doseq [p sec-patches]
                      (doseq [cr (check-contract (readFileSync (join PATCHES-DIR p) "utf8"))]
                        (when (= (.-verdict cr) "not-found")
                          (.push unresolved (str p ": " (.-kind cr) " `" (.-symbol cr) "` — " (.-detail cr))))))
                    (if (or (> (.-length failed) 0) (> (.-length unresolved) 0))
                      (fail "S" "security-critical patches persist (#120)"
                        (str (.-length sec-patches) " security-tagged patch(es): "
                             (.-length failed) " apply-failure(s), " (.-length unresolved) " unresolved anchor(s) — HARD STOP (a security mitigation regressed)")
                        (str "a security-critical patch no longer applies or its upstream anchor moved — regenerate it BEFORE building; do not ship the regression:\n"
                             "    apply:    " (.join failed "\n              ") "\n"
                             "    anchors:  " (.join unresolved "\n              ")))
                      (pass "S" "security-critical patches persist (#120)"
                        (str (.-length sec-patches) " security-tagged patch(es) apply cleanly + all declared anchors resolve")))))))))))))

;; Gate T — stewardship tapestry: every gate/file/script the docs/stewardship/
;; docs name resolves, and the generated topology.md is current. The manifesto's
;; "if a name here stops resolving, that is a bug" made mechanical; fails closed.
(defn gateT [] :- Any
  (try
    (let [out (.toString (execSync "bun tools/stewardship/topology.mjs check 2>&1"))]
      (pass "T" "stewardship tapestry intact (docs ↔ machinery)" (.trim out)))
    (catch Any e
      (fail "T" "stewardship tapestry intact (docs ↔ machinery)"
            (.trim (if (.-stdout e) (.toString (.-stdout e)) (or (.-message e) "check failed")))
            "a docs/stewardship/ ref dangled or topology.md is stale — `bun run stewardship:gen`, then commit"))))

;; Gate U — patch numbering coherence (#128): every subsystem domain occupies a
;; contiguous numeric block (no foreign patch wedged into another domain's run).
;; Advisory (WARN, not a build stop) — alpha-apply order is sound regardless; a
;; split domain is a batching/comprehension smell with a known minimal renumber.
(defn gateU [] :- Any
  (try
    (let [out (.toString (execSync "bun .beagle-tools/gjoa/tools/prep/patch-order.js check --strict 2>&1"))]
      (pass "U" "patch numbering coherent (domains contiguous)" (.trim out)))
    (catch Any e
      (warn "U" "patch numbering coherent (domains contiguous)"
            (.trim (if (.-stdout e) (.toString (.-stdout e)) (or (.-message e) "split domain — see `patch-order renumber`")))))))

;; Gate V — upstream provenance lock currency (churn). The lock records the git
;; blob OID of every patched file at the baseline FF tag; integrity mode asserts
;; the lock still describes the current patch surface at the declared baseline.
;; Skip-aware (the FF clone is dev-only, absent on CI) + WARN (stale lock is
;; hygiene, not a build stop).
(defn gateV [] :- Any
  (try
    (let [out (.toString (execSync "bun .beagle-tools/gjoa/tools/prep/upstream-provenance.js check --strict 2>&1"))]
      (pass "V" "upstream provenance lock current" (.trim out)))
    (catch Any e
      (warn "V" "upstream provenance lock current"
            (.trim (if (.-stdout e) (.toString (.-stdout e)) (or (.-message e) "stale lock — re-run `provenance lock`")))))))

;; Gate W — dark-mode contrast backstop ships ON (#129). The APCA normalizer is
;; the no-black-on-black backstop (drawSnapshot real pixels → APCA Lc per text →
;; re-tone below the readable floor). It shipped DISABLED for months — 8 user
;; reports of unreadable dark mode, empirically 7/9 text elements black-on-black
;; with it off, 7→0 with it on. Assert the shipped default is true so the
;; legibility floor can't silently regress. HARD: shipping it off is a real
;; user-facing defect, not a style choice. (The suite already measures the
;; shipped config, so a green contrast run now equals the browser users run.)
(defn gateW [] :- Any
  (let [f (join PREF-DIR "dark-mode-prefs.bjs")]
    (if (not (existsSync f))
      (warn "W" "dark-mode contrast backstop ships ON" "dark-mode-prefs.bjs absent — skipping")
      (let [src (readFileSync f "utf8")]
        (if (.match src (RegExp. "\\(pref\\s+\"gjoa\\.darkmode\\.normalize\\.enabled\"\\s+true\\)"))
          (pass "W" "dark-mode contrast backstop ships ON" "gjoa.darkmode.normalize.enabled defaults true (APCA no-black-on-black backstop active)")
          (fail "W" "dark-mode contrast backstop ships ON"
                "gjoa.darkmode.normalize.enabled is not defaulted true in dark-mode-prefs.bjs"
                "the APCA backstop fixes the recurring unreadable-dark-mode reports — restore the `true` default; if disabling deliberately, update Gate W with the rationale"))))))

;; ── Run + render ──────────────────────────────────────────────────────────
(defn main! [] :- Any
  (console/log (bold "gjoa preflight"))
  (console/log (dim "Mandatory gate before any nix or full-mach build (CLAUDE.md Rule #0)."))
  (console/log "")

  (let [gates [["A" gateA!] ["B" gateB] ["C" gateC] ["D" gateD]
               ["E" gateE] ["F" gateF] ["G" gateG] ["H" gateH]
               ["I" gateI] ["J" gateJ] ["K" gateK] ["L" gateL] ["M" gateM]
               ["N" gateN] ["O" gateO] ["P" gateP] ["Q" gateQ]
               ["R" gateR] ["S" gateS!] ["T" gateT] ["U" gateU] ["V" gateV]
               ["W" gateW]]]
    (doseq [gate gates]
      (let [fn (aget gate 1)]
        (try (fn)
          (catch Error e (fail "?" (.-name fn) "gate threw" (.-message e)))))))

  (doseq [r results]
    (let [mark (cond (.-warned r) (yellow "⚠")
                     (.-passed r) (green "✓")
                     :else (red "✗"))]
      (console/log (str mark "  " (bold (.-id r)) "  " (.-name r)))
      (console/log (str "     " (dim (.-detail r))))
      (when (and (not (.-passed r)) (.-fix r))
        (console/log (str "     " (yellow (str "fix: " (.join (.split (.-fix r) "\n") "\n          "))))))))

  (let [failed (.-length (.filter results (fn [r] (not (.-passed r)))))]
    (console/log "")
    (if (= failed 0)
      (do
        (console/log (str (green (bold "PREFLIGHT GREEN")) (dim (str "  — " (.-length results) "/" (.-length results) " gates passed"))))
        (console/log (dim "Safe to propose a rebuild. Show this output in the proposal."))
        (.exit process 0))
      (do
        (console/log (str (red (bold "PREFLIGHT FAILED")) (dim (str "  — " failed "/" (.-length results) " gates failed"))))
        (console/log (red "Do NOT kick off a build until every gate is green."))
        (.exit process 1)))))

;; The .ts guarded on `import.meta.main`; there is no import.meta in beagle, and
;; Errors abort with exit 1, matching the original `.catch` handler. Guarded so
;; the CLI runs only when invoked directly, never on import.
(when (.-main (js/import-meta))
  (.catch (main!) (fn [e] (console/error e) (.exit process 1))))
