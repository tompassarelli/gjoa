#lang beagle/js
;; security:bump — write the latest Mozilla stable Firefox version into
;; gjoa.json (firefox.version + firefox.candidate). Non-interactive.
;;
;; Run after this:  bun run import  (regenerates engine/ from the new pin)
;;
;; Flags:
;;   --check    Just print what the new pin would be; don't write.
;;   --esr      Use the ESR track instead of latest stable.
(ns gjoa.tools.security.bump
  (:require [fs/promises :refer [readFile writeFile]]
            [path :refer [join]]
            [gjoa.tools.prep.paths :refer [REPO-ROOT]]))
(define-mode strict)
(declare-extern [fetch AbortSignal] Any)

(def PRODUCT-DETAILS-URL :- String
  "https://product-details.mozilla.org/1.0/firefox_versions.json")

(defn fetchVersions [] :- Any
  (let [r (js/await (fetch PRODUCT-DETAILS-URL {:signal (.timeout AbortSignal 10000)}))]
    (if (not (.-ok r))
      (throw (Error. (str "product-details HTTP " (.-status r))))
      nil)
    (js/await (.json r))))

(defn main! [] :- Any
  (let [esrMode (.includes (.-argv process) "--esr")
        checkOnly (.includes (.-argv process) "--check")
        versions (js/await (fetchVersions))
        latest (if esrMode
                 (.replace (.-FIREFOX_ESR versions) (RegExp. "esr$" "i") "")
                 (.-LATEST_FIREFOX_VERSION versions))
        path (join REPO-ROOT "gjoa.json")
        text (js/await (readFile path "utf8"))
        cfg (JSON/parse text)
        oldVersion (.-version (.-firefox cfg))]

    (if (= oldVersion latest)
      (do
        (console/error (str "[bump] gjoa.json already at " latest " — no change."))
        (.exit process 0))
      nil)

    (console/error (str "[bump] " oldVersion "  →  " latest (if esrMode "  (ESR)" "")))

    (if checkOnly
      (do
        (console/error "[bump] --check: not writing. Re-run without --check to apply.")
        (.exit process 0))
      nil)

    (set! (.-version (.-firefox cfg)) latest)
    (set! (.-candidate (.-firefox cfg)) latest)
    (set! (.-candidateBuild (.-firefox cfg)) 1)

    ;; Preserve the user's indentation by re-stringifying with 2 spaces (the
    ;; existing file uses 2-space indent and ends with a single trailing
    ;; newline, per Mozilla convention).
    (js/await (writeFile path (str (JSON/stringify cfg nil 2) "\n") "utf8"))
    (console/error "[bump] wrote gjoa.json")
    (console/error "")
    (console/error "Next steps:")
    (console/error "  1. bun run import      # re-download tarball, re-apply overlays")
    (console/error "  2. nix build .#gjoa --impure   # full rebuild (Lane 3)")
    (console/error "  3. relaunch — verify everything still works")
    (console/error "")
    (console/error "If the new version breaks something, restore the pin from git:")
    (console/error "  git checkout gjoa.json")))

(.catch (main!)
  (fn [err]
    (console/error (str "[bump] failed: " (.-message err)))
    (.exit process 1)))
