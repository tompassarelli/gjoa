#lang beagle/js
;; Ephemeral test-profile factory.
;;
;; gjoa doesn't need a per-profile chrome/ copy the way palefox did —
;; chrome JS gets loaded by gjoa's built-in loader from
;; <install_root>/gjoa-dev/, not from the profile. So all we need is
;; a fresh profile dir with a user.js that enables Marionette and
;; silences interruptions.
(ns gjoa.tools.test-driver.profile
  (:require [fs/promises :refer [mkdtemp writeFile rm]]
            [path :refer [join]]
            [os :refer [tmpdir]]))
(define-mode strict)

;; TestProfile (TS interface, no runtime emission):
;;   path     — absolute path to the ephemeral profile directory.
;;   cleanup  — removes the profile directory; call from a finally block.

(def DEFAULT-USER-JS :- String
  (str
    "// Generated by tools/test-driver — DO NOT EDIT.\n"
    "// Marionette (marionette.port is prepended per-run by create-profile)\n"
    "user_pref(\"marionette.enabled\", true);\n"
    "// No update / first-run / what's-new interruptions\n"
    "user_pref(\"app.update.enabled\", false);\n"
    "user_pref(\"app.update.auto\", false);\n"
    "user_pref(\"app.update.silent\", false);\n"
    "user_pref(\"app.update.checkInstallTime\", false);\n"
    "user_pref(\"browser.startup.homepage_override.mstone\", \"ignore\");\n"
    "user_pref(\"browser.shell.checkDefaultBrowser\", false);\n"
    "// Don't let the niri workspace binding spawn a subprocess + switch spaces\n"
    "// mid-test if the suite runs inside a live niri session.\n"
    "user_pref(\"gjoa.niri.enabled\", false);\n"
    "user_pref(\"browser.startup.homepage\", \"about:blank\");\n"
    "user_pref(\"startup.homepage_welcome_url\", \"\");\n"
    "user_pref(\"startup.homepage_welcome_url.additional\", \"\");\n"
    "user_pref(\"startup.homepage_override_url\", \"\");\n"
    "user_pref(\"browser.tabs.warnOnClose\", false);\n"
    "user_pref(\"browser.tabs.warnOnCloseOtherTabs\", false);\n"
    "// Restore previous session — needed for tree-reconciliation tests\n"
    "user_pref(\"browser.startup.page\", 3);\n"
    "user_pref(\"browser.sessionstore.resume_from_crash\", true);\n"
    "user_pref(\"toolkit.startup.max_resumed_crashes\", -1);\n"
    "// Vertical tabs on (gjoa-tabs default territory)\n"
    "user_pref(\"sidebar.verticalTabs\", true);\n"
    "user_pref(\"sidebar.revamp\", true);\n"
    "// Telemetry off\n"
    "user_pref(\"toolkit.telemetry.enabled\", false);\n"
    "user_pref(\"toolkit.telemetry.unified\", false);\n"
    "user_pref(\"datareporting.policy.dataSubmissionEnabled\", false);\n"
    "user_pref(\"datareporting.healthreport.uploadEnabled\", false);\n"
    "// Gjoa-tabs internal prefs (port kept the gjoa.* namespace)\n"
    "user_pref(\"gjoa.debug\", true);\n"
    "// Exposes window.gjoaTest = { vim, state, history, … } so integration\n"
    "// tests can drive the chrome layer past public surfaces.\n"
    "user_pref(\"gjoa.test.exposeAPI\", true);\n"))

(js/export (defn create-profile [opts :- Any] :- Any
  ;; opts defaults to {} (TS `opts = {}`); callers invoke create-profile() with
  ;; no args, so guard against an undefined opts before reading .extraPrefs.
  (let [o (or opts {})
        ;; Marionette reads its port from the marionette.port PREF, not the
        ;; -marionette-port CLI arg (which Firefox silently ignores). Seed it
        ;; per-run so agents sharing one tree can run concurrently on distinct
        ;; ports. Default 2828 keeps single-agent + no-arg callers unchanged.
        port (or (.-marionettePort o) 2828)
        path (js/await (mkdtemp (join (tmpdir) "gjoa-test-")))
        portPref (str "user_pref(\"marionette.port\", " port ");\n")
        userJs (str portPref DEFAULT-USER-JS (or (.-extraPrefs o) ""))]
    (js/await (writeFile (join path "user.js") userJs "utf8"))
    {:path path
     :cleanup (fn []
                (js/await (rm path {:recursive true :force true})))})))
