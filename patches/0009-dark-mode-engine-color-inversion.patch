+/// gjoa engine-level dark mode: invert a color's lightness into a comfortable
+/// dark band while preserving hue, chroma, and alpha. The compression is done in
+/// OKLCH (perceptually uniform, the same space as the 0013 text retone), NOT a
+/// full WCAG luminance flip — a flip maps white to BLACK, which is the
+/// "too dark" defect. Here the page's OKLCH lightness L in [0, 1] is mapped
+/// linearly onto [floor, ceiling]:
+///     L_out = ceiling - L * (ceiling - floor)
+/// so white (L=1) lands on `floor` (a comfortable dark, e.g. L~0.20 => ~#161616,
+/// in the Dark Reader #1a1a1a band, NOT black) and black (L=0) lands on `ceiling`
+/// (a comfortable light, e.g. L~0.92 => ~#e4e4e4, NOT pure white). Only L moves;
+/// the OKLCH chroma (c1) and hue (c2) are carried through untouched, so hue and
+/// saturation are preserved, and alpha is preserved by the conversion. `floor`
+/// and `ceiling` are live prefs surfaced as gjoa.darkmode.invert.bgLightness /
+/// fgLightness (read in nsPresContext::UpdateColorInversion).
+fn invert_color_luminance(color: &AbsoluteColor, floor: f32, ceiling: f32) -> AbsoluteColor {
+    let oklch = color.to_color_space(ColorSpace::Oklch);
+    let l_in = oklch.c0().unwrap_or(0.0);
+    let l_out = (ceiling - l_in * (ceiling - floor)).clamp(0.0, 1.0);
+    // Rebuild in OKLCH holding chroma (c1) and hue (c2); preserve missing
+    // components and alpha. The cascade resolves the OKLCH value like any other
+    // absolute color (serialized/painted via to_color_space(Srgb)).
+    AbsoluteColor::new(ColorSpace::Oklch, l_out, oklch.c1(), oklch.c2(), oklch.alpha())
+}
+
+/// gjoa dark mode: WCAG relative luminance (0..1) of a color, used to decide
+/// whether inherited text under an image-backdrop hero is already light (preserve
+/// it) or dark (let it invert to light) — so hero text always reads on the scrim.
+fn color_relative_luminance(color: &AbsoluteColor) -> f32 {
+    let c = color.to_nscolor();
+    let r = (c & 0xff) as u8;
+    let g = ((c >> 8) & 0xff) as u8;
+    let b = ((c >> 16) & 0xff) as u8;
+    let compute = |u: u8| -> f32 {
+        let f = u as f32 / 255.0;
+        if f <= 0.03928 {
+            f / 12.92
+        } else {
+            ((f + 0.055) / 1.055).powf(2.4)
+        }
+    };
+    0.2126 * compute(r) + 0.7152 * compute(g) + 0.0722 * compute(b)
+}
