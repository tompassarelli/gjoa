+  if (mColorInversion && scheme == ColorScheme::Light) {
+    float lIn = std::pow(RelativeLuminanceUtils::Compute(bg), 1.0f / 3.0f);
+    float lOut = mColorInversionCeilL -
+                 lIn * (mColorInversionCeilL - mColorInversionFloorL);
+    lOut = std::max(0.0f, std::min(1.0f, lOut));
+    bg = RelativeLuminanceUtils::Adjust(bg, lOut * lOut * lOut);
+  }
+  return bg;
 }
 
