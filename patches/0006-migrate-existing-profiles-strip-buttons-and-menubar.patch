Force-migrate existing profiles to the new toolbar + menubar defaults.

Patches 0004 (menubar autohide=false) and 0005 (strip 3 default buttons)
change the *source defaults* — but Firefox persists toolbar layout and
the menubar autohide attribute to the user's profile (xulStore.json)
after first run. So source-default changes only affect fresh profiles.

This patch makes the change apply to *every* existing profile on next
launch, as a one-shot migration. Mechanism is the same as every other
CustomizableUI bump:

  1. kVersion bumped 23 -> 24.
  2. New `currentVersion < 24` block iterates every saved placements
     area and filters out the three button ids.
  3. Same block clears the persisted `autohide` attribute on
     `#toolbar-menubar` from xulStore so the new `autohide="false"`
     XUL default (from patch 0004) takes effect.

Migration is a no-op on fresh profiles (their saved layout already
matches the new defaults from patch 0005). Idempotent on re-runs.

diff --git a/browser/components/customizableui/CustomizableUI.sys.mjs b/browser/components/customizableui/CustomizableUI.sys.mjs
--- a/browser/components/customizableui/CustomizableUI.sys.mjs
+++ b/browser/components/customizableui/CustomizableUI.sys.mjs
@@ -68,7 +68,7 @@ const kSubviewEvents = ["ViewShowing", "ViewHiding"];
  * The current version. We can use this to auto-add new default widgets as necessary.
  * (would be const but isn't because of testing purposes)
  */
-var kVersion = 23;
+var kVersion = 24;

 /**
  * Buttons removed from built-ins by version they were removed. kVersion must be
@@ -848,6 +848,32 @@ var CustomizableUIInternal = {
       if (buttonIndex != -1) {
         navbarPlacements.splice(buttonIndex, 1);
       }
     }
+
+    // Gjoa: drop three buttons we hide by default from any existing
+    // profile's saved layout, and reset the menubar autohide so the new
+    // default (autohide="false") takes effect on next launch. Paired
+    // with patches 0004 + 0005 which change the source defaults — this
+    // block carries the change forward into pre-existing profiles
+    // whose layout was saved before those defaults landed.
+    if (currentVersion < 24) {
+      const STRIPPED = new Set([
+        "fxa-toolbar-menu-button",
+        "firefox-view-button",
+        "alltabs-button",
+      ]);
+      for (const area of Object.keys(gSavedState.placements)) {
+        const arr = gSavedState.placements[area];
+        if (!Array.isArray(arr)) {
+          continue;
+        }
+        gSavedState.placements[area] = arr.filter(id => !STRIPPED.has(id));
+      }
+      Services.xulStore.removeValue(
+        "chrome://browser/content/browser.xhtml",
+        "toolbar-menubar",
+        "autohide"
+      );
+    }
   },

   /**
