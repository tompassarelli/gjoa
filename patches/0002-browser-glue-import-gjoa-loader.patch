Wire GjoaLoader into BrowserGlue._init so it runs at app-startup.
GjoaLoader.start() registers the chrome-document-loaded observer that
loads our chrome JS/CSS into each browser window.

Source-of-truth implementation lives at
browser/components/gjoa/GjoaLoader.sys.mjs (registered as
resource:///modules/gjoa/ via gjoa/moz.build's EXTRA_JS_MODULES).

diff --git a/browser/components/BrowserGlue.sys.mjs b/browser/components/BrowserGlue.sys.mjs
--- a/browser/components/BrowserGlue.sys.mjs
+++ b/browser/components/BrowserGlue.sys.mjs
@@ -356,6 +356,11 @@ BrowserGlue.prototype = {
     }

     lazy.DesktopActorRegistry.init();
+
+    // Gjoa chrome JS/CSS loader. See browser/components/gjoa/GjoaLoader.sys.mjs.
+    ChromeUtils.importESModule(
+      "resource:///modules/gjoa/GjoaLoader.sys.mjs",
+    ).GjoaLoader.start();
   },

   // cleanup (called on application shutdown)
