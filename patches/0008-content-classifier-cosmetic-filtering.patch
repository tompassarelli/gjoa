+/// Load a scriptlet/redirect resource library (uBO-style, JSON-serialized
+/// `Vec<adblock::resources::Resource>`) into the engine. Without this, the
+/// engine cannot expand `+js(...)` cosmetic rules, so `injected_script` is
+/// always empty. Call once after `from_rules`.
+#[no_mangle]
+pub unsafe extern "C" fn content_classifier_engine_use_resources(
+    engine: *mut ContentClassifierFFIEngine,
+    resources_json: &nsACString,
+) -> nsresult {
+    if engine.is_null() {
+        return NS_ERROR_INVALID_ARG;
+    }
+    let json = String::from_utf8_lossy(resources_json.as_ref()).to_string();
+    let resources: Vec<adblock::resources::Resource> = match serde_json::from_str(&json) {
+        Ok(r) => r,
+        Err(_) => return NS_ERROR_INVALID_ARG,
+    };
+    let engine = &mut (*engine).engine;
+    engine.use_resources(resources);
+    NS_OK
+}
