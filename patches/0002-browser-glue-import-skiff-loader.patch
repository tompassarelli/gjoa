Wire SkiffLoader into BrowserGlue._init so it runs at app-startup.
SkiffLoader.start() registers the chrome-document-loaded observer that
loads our chrome JS/CSS into each browser window.

Source-of-truth implementation lives at
browser/components/skiff/SkiffLoader.sys.mjs (registered as
resource:///modules/skiff/ via skiff/moz.build's EXTRA_JS_MODULES).

diff --git a/browser/components/BrowserGlue.sys.mjs b/browser/components/BrowserGlue.sys.mjs
--- a/browser/components/BrowserGlue.sys.mjs
+++ b/browser/components/BrowserGlue.sys.mjs
@@ -356,6 +356,11 @@ BrowserGlue.prototype = {
     }

     lazy.DesktopActorRegistry.init();
+
+    // Skiff chrome JS/CSS loader. See browser/components/skiff/SkiffLoader.sys.mjs.
+    ChromeUtils.importESModule(
+      "resource:///modules/skiff/SkiffLoader.sys.mjs",
+    ).SkiffLoader.start();
   },

   // cleanup (called on application shutdown)
