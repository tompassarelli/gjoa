+
+        // gjoa dark mode: flag elements that establish a full-bleed RASTER image
+        // backdrop (a hero photo) so the cascade foreground-inversion hook
+        // preserves authored text over it and the paint stage scrims it — rather
+        // than flipping light hero text to black over an untouched dark image.
+        // Only stretched (cover/contain), non-tiled url()/image-set layers
+        // qualify; gradients are recolored in place, and tiled/decorative images
+        // are excluded (the over-fire ChatGPT's naive "has background-image"
+        // predicate would cause). The bit is inherited, so a hero's descendants
+        // (its text) inherit it.
+        #[cfg(feature = "gecko")]
+        if !display.is_contents() {
+            use crate::values::generics::background::GenericBackgroundSize;
+            use crate::values::generics::image::GenericImage;
+            use crate::values::specified::background::BackgroundRepeatKeyword;
+            let bg = self.style.get_background();
+            // Gecko's Background exposes layers via clone_* accessors, not direct
+            // fields (that's the servo-only path). The clones are cheap here — most
+            // elements have a single `none` image layer.
+            let image_list = bg.clone_background_image();
+            let size_list = bg.clone_background_size();
+            let repeat_list = bg.clone_background_repeat();
+            let images = &image_list.0;
+            let sizes = &size_list.0;
+            let repeats = &repeat_list.0;
+            let mut hero = false;
+            for (i, image) in images.iter().enumerate() {
+                if !matches!(image, GenericImage::Url(..) | GenericImage::ImageSet(..)) {
+                    continue;
+                }
+                // background-size / -repeat lists may be shorter than the image
+                // list; CSS repeats them, so index modulo their length.
+                let size = &sizes[i % sizes.len()];
+                let stretched = matches!(
+                    size,
+                    GenericBackgroundSize::Cover | GenericBackgroundSize::Contain
+                );
+                let r = &repeats[i % repeats.len()];
+                let tiled = !matches!(r.0, BackgroundRepeatKeyword::NoRepeat)
+                    || !matches!(r.1, BackgroundRepeatKeyword::NoRepeat);
+                if stretched && !tiled {
+                    hero = true;
+                    break;
+                }
+            }
+            if hero {
+                self.style
+                    .add_flags(ComputedValueFlags::SELF_OR_ANCESTOR_HAS_IMAGE_BACKDROP);
+            }
+        }
     }
 
     /// Adjust the style for text style.
