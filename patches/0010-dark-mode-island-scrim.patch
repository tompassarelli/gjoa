+// gjoa dark mode: paint a translucent dark scrim over a hero photo's background
+// images (but under its content) so the inversion-preserved authored text stays
+// readable against the still-bright image. Gated on content color inversion and
+// on this frame establishing a stretched, non-tiled raster image backdrop.
+static void MaybeAppendDarkScrim(nsDisplayListBuilder* aBuilder,
+                                 nsIFrame* aFrame,
+                                 nsIFrame* aSecondaryReferenceFrame,
+                                 const nsRect& aBackgroundRect,
+                                 const ComputedStyle* aBgSC,
+                                 const nsStyleBorder& aBorder,
+                                 nsDisplayList* aBgItemList) {
+  if (!aFrame->PresContext()->ColorInversion()) {
+    return;
+  }
+
+  // The SELF_OR_ANCESTOR_HAS_IMAGE_BACKDROP ComputedValueFlags bit is only
+  // reachable through ComputedStyle's private Flags(), so re-derive the hero
+  // condition from the bottom background layer: a stretched (cover/contain),
+  // non-tiled url()/image-set raster image, matching style_adjuster.rs.
+  const nsStyleImageLayers::Layer& layer = aBgSC->StyleBackground()->BottomLayer();
+  const bool isRaster = layer.mImage.IsUrl() || layer.mImage.IsImageSet();
+  const bool stretched = layer.mSize.IsCover() || layer.mSize.IsContain();
+  const bool tiled =
+      layer.mRepeat.mXRepeat != StyleImageLayerRepeat::NoRepeat ||
+      layer.mRepeat.mYRepeat != StyleImageLayerRepeat::NoRepeat;
+  if (!isRaster || !stretched || tiled) {
+    return;
+  }
+
+  const uint8_t alpha = (uint8_t)std::clamp(
+      mozilla::Preferences::GetInt("gjoa.darkmode.scrim.alpha", 140), 0, 255);
+
+  Maybe<DisplayListClipState::AutoSaveRestore> clipState;
+  nsRect scrimRect = aBackgroundRect;
+  nsCSSRendering::ImageLayerClipState clip;
+  nsCSSRendering::GetImageLayerClip(
+      aBgSC->StyleBackground()->BottomLayer(), aFrame, aBorder, aBackgroundRect,
+      aBackgroundRect, false, aFrame->PresContext()->AppUnitsPerDevPixel(),
+      &clip);
+
+  scrimRect = scrimRect.Intersect(clip.mBGClipArea);
+  if (clip.mHasAdditionalBGClipArea) {
+    scrimRect = scrimRect.Intersect(clip.mAdditionalBGClipArea);
+  }
+  if (clip.mHasRoundedCorners) {
+    clipState.emplace(aBuilder);
+    clipState->ClipContentDescendants(clip.mBGClipArea, &clip.mRadii);
+  }
+
+  nsDisplayBackgroundColor* scrim =
+      CreateBackgroundColor(aBuilder, aFrame, aSecondaryReferenceFrame,
+                            scrimRect, aBgSC, NS_RGBA(0, 0, 0, alpha));
+  if (scrim) {
+    aBgItemList->AppendToTop(scrim);
+  }
+}
