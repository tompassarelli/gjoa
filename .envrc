use flake

# Thermal cap on parallel compilation. This machine has 24 logical cores;
# unconstrained mach builds peg all of them and previously caused a crash
# from sustained CPU heat. 8 leaves substantial headroom for the cooler
# to keep up across a 30-60 min build without throttling.
#
# Override per-shell with `MOZ_PARALLEL_BUILD=N` if you have specific
# reason (cooler machine, time-sensitive build).
export MOZ_PARALLEL_BUILD=8

# Print the security status when entering the gjoa repo — surfaces
# stale pins without requiring you to remember to run `bun run security:check`.
# Suppressed if direnv's quiet mode is on (`direnv --quiet allow`).
if command -v bun > /dev/null 2>&1; then
  if STATUS=$(bun .beagle-tools/gjoa/tools/security/check.js --json 2>/dev/null); then
    SUMMARY=$(echo "$STATUS" | grep -oE '"summary":"[^"]*"' | head -1 | sed 's/"summary":"\(.*\)"/\1/')
    LABEL=$(echo "$STATUS" | grep -oE '"status":"[^"]*"' | head -1 | sed 's/"status":"\(.*\)"/\1/')
    case "$LABEL" in
      OK)       echo "[gjoa] security: OK — $SUMMARY" ;;
      STALE)    echo "[gjoa] security: STALE — $SUMMARY  (bun run security:bump to fix)" ;;
      CRITICAL) echo "[gjoa] security: CRITICAL — $SUMMARY  (bun run security:bump NOW)" ;;
      UNKNOWN)  : ;;  # offline; stay quiet
    esac
  fi
fi
