use flake

# Pin the beagle COMPILER (not just the vendored runtime) to the frozen worktree at
# configs/beagle.ref. Without this, beagle-build resolves the beagle Racket collection
# via the user-global raco link to the LIVE, moving ~/code/beagle — so local builds
# emit with today's beagle while we vendor a frozen core.js, and emit/runtime skew
# (the equivV break). PLTCOLLECTS makes racket resolve `beagle` from the pinned
# worktree FIRST, so local uses the SAME compiler as CI. Scoped to gjoa; the fleet's
# global link is untouched. Re-point ~/code/beagle-pin when bumping configs/beagle.ref.
BEAGLE_PIN_ROOT="${BEAGLE_PIN_ROOT:-$HOME/code/beagle-pin}"
if [ -d "$BEAGLE_PIN_ROOT/beagle-lib" ]; then
  mkdir -p "$PWD/.beagle-pin-collects"
  ln -sfn "$BEAGLE_PIN_ROOT/beagle-lib" "$PWD/.beagle-pin-collects/beagle"
  export PLTCOLLECTS="$PWD/.beagle-pin-collects:"
  # The compiled .bjs tooling imports the $$bc runtime as `beagle/core.js`; bun
  # resolves that via node_modules/beagle. Point it at the PINNED worktree too
  # (it was an orphaned symlink to live ~/code/beagle — the third non-hermetic
  # beagle link). CI does the same after its pinned beagle checkout.
  mkdir -p "$PWD/node_modules"
  ln -sfn "$BEAGLE_PIN_ROOT/beagle-lib/lib/beagle" "$PWD/node_modules/beagle"
fi

# Pinned fram worktree for the code-as-claims projector (tools/projector/*), at
# configs/fram.ref (the FLEET pin, ~/code/fram-pin). gjoa's projector floats on a
# known-good fram, isolated from fram-2's self-host churn (a separate worktree, not
# in fram main). Mirrors BEAGLE_PIN_ROOT; re-point ~/code/fram-pin when bumping
# configs/fram.ref. fram is a DEV-TOOL dep only — never the browser build.
export FRAM_PIN_ROOT="${FRAM_PIN_ROOT:-$HOME/code/fram-pin}"

# Thermal cap on parallel compilation. This machine has 24 logical cores;
# unconstrained mach builds peg all of them and previously caused a crash
# from sustained CPU heat. 8 leaves substantial headroom for the cooler
# to keep up across a 30-60 min build without throttling.
#
# Override per-shell with `MOZ_PARALLEL_BUILD=N` if you have specific
# reason (cooler machine, time-sensitive build).
export MOZ_PARALLEL_BUILD=8

# Print the security status when entering the gjoa repo — surfaces
# stale pins without requiring you to remember to run `bun run security:check`.
# Suppressed if direnv's quiet mode is on (`direnv --quiet allow`).
if command -v bun > /dev/null 2>&1; then
  if STATUS=$(bun .beagle-tools/gjoa/tools/security/check.js --json 2>/dev/null); then
    SUMMARY=$(echo "$STATUS" | grep -oE '"summary":"[^"]*"' | head -1 | sed 's/"summary":"\(.*\)"/\1/')
    LABEL=$(echo "$STATUS" | grep -oE '"status":"[^"]*"' | head -1 | sed 's/"status":"\(.*\)"/\1/')
    case "$LABEL" in
      OK)       echo "[gjoa] security: OK — $SUMMARY" ;;
      STALE)    echo "[gjoa] security: STALE — $SUMMARY  (bun run security:bump to fix)" ;;
      CRITICAL) echo "[gjoa] security: CRITICAL — $SUMMARY  (bun run security:bump NOW)" ;;
      UNKNOWN)  : ;;  # offline; stay quiet
    esac
  fi
fi
