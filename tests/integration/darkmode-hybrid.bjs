#lang beagle/js
;; Per-site dark-mode HYBRID (task #43), tested through the REAL production path:
;; the GjoaDarkmode actor measures the rendered page background in the content
;; process and sets BrowsingContext.colorInversionOverride, which drives
;; nsPresContext::mColorInversion for THAT document. A themeless light page must
;; be inverted ("active"). The actor's content-process set is what propagates the
;; engine recompute, so we exercise the real actor — not a chrome-side override poke.
;;
;; The native-dark "keep" path (actor -> "inactive", no double-darken) is verified
;; correct in isolation (the actor measures rgb(17,17,17) -> "inactive"), but a
;; reliable cross-navigation test needs the Tier-b engine fix: today the override
;; persists across a same-tab navigation, so a native-dark page entered from a
;; themeless (inverted) one is measured AFTER inversion (circular). Tier b reads
;; the authored bg pre-paint and dissolves that circularity; the "inactive"
;; assertion lands there.
(ns gjoa.tests.integration.darkmode-hybrid
  (:require [gjoa.tests.dsl :refer [deftest chrome-eval await-true wait-for expect expect-eq NAV-JS]]))
(define-mode strict)
(declare-extern [Number] Any)

(def TOP :- String "http://127.0.0.1:8975/") ;; no-bg page (UA-dark under hybrid)
(def LIGHT-TOP :- String "http://127.0.0.1:8975/light") ;; hardcoded-light themeless site

;; Hybrid on; global engine invert OFF so ONLY the actor's per-document decision
;; can invert.
(def HYBRID-JS :- String
  (str "Services.prefs.setBoolPref('gjoa.darkmode.enabled', true);"
       " Services.prefs.setStringPref('gjoa.darkmode.mode', 'hybrid');"
       " Services.prefs.setBoolPref('gjoa.darkmode.invert.enabled', false);"
       " return 'hybrid';"))

;; Inject an explicit white-bg / black-text probe box into the content doc.
(def INJECT-BOX :- String
  (str "const d=document.createElement('div'); d.id='dm-hy';"
       " d.style.backgroundColor='rgb(255,255,255)'; d.style.color='rgb(0,0,0)';"
       " document.body.appendChild(d); return 'injected';"))

;; Tier b: hybrid + the engine pre-paint default-invert. A themeless top doc is
;; inverted by the ENGINE at construction (no actor round-trip); a native-dark
;; page is retracted pre-paint (PresShell::Initialize) and keeps its theme.
(def HYBRID-B-JS :- String
  (str "Services.prefs.setBoolPref('gjoa.darkmode.enabled', true);"
       " Services.prefs.setStringPref('gjoa.darkmode.mode', 'hybrid');"
       " Services.prefs.setBoolPref('gjoa.darkmode.invert.enabled', false);"
       " Services.prefs.setBoolPref('gjoa.darkmode.hybrid.default-invert', true);"
       " return 'hybrid-b';"))

(def DARK-TOP :- String "http://127.0.0.1:8975/dark") ;; authored-dark (#111) fixture

;; Inject a plain white box (no explicit text color) to probe inversion state.
(def INJECT-WHITE :- String
  (str "const d=document.createElement('div'); d.id='dm-w';"
       " d.style.backgroundColor='rgb(255,255,255)';"
       " document.body.appendChild(d); return 'injected';"))

;; Chrome-side settle so the post-paint actor refiner has a chance to (wrongly)
;; re-invert before we assert it did not. Marionette has no content setTimeout.
(def SETTLE-JS :- String
  "const r=arguments[arguments.length-1]; setTimeout(()=>r(1), 700);")

;; Chrome-side drawSnapshot luminance at pixel (px,py) of `url` (0=black..255=white).
;; No content executeScript -> survives engine inversion (which discards the content BC).
(defn render-lum-js [url :- String px :- Int py :- Int] :- String
  (str "const done = arguments[arguments.length-1];"
       "(async () => { try {"
       "  const win = Services.wm.getMostRecentWindow('navigator:browser');"
       "  const b = win.gBrowser.selectedBrowser;"
       "  b.loadURI(Services.io.newURI('" url "'), {triggeringPrincipal: Services.scriptSecurityManager.getSystemPrincipal()});"
       "  await new Promise(r => win.setTimeout(r, 3500));"
       "  const wg = b.browsingContext.currentWindowGlobal;"
       "  const bm = await wg.drawSnapshot(new win.DOMRect(0,0,300,200), 1, 'rgb(128,128,128)');"
       "  const c = new win.OffscreenCanvas(300,200); const x = c.getContext('2d'); x.drawImage(bm,0,0);"
       "  const d = x.getImageData(" px "," py ",1,1).data;"
       "  done(String(Math.round(0.2126*d[0] + 0.7152*d[1] + 0.0722*d[2])));"
       "} catch(e){ done('ERR:'+(e&&e.message||e)); } })();"))

(js/export (def tests :- Any
  [(deftest "darkmode hybrid: actor inverts a themeless (light) page (painted, chrome-side)" [mn ctx]
     (js/await (.setContext mn "chrome"))
     (chrome-eval HYBRID-JS)
     ;; actor measures /light -> 'active' -> sets colorInversionOverride -> recascade.
     ;; Read the PAINTED page chrome-side (content getComputedStyle discards under invert).
     (let [lum (js/await (.executeAsyncScript mn (render-lum-js LIGHT-TOP 150 100) []))]
       (console/log (str "[dm-hybrid] actor /light center-lum=" lum))
       (expect (< (Number lum) 80) (str "themeless-light should invert to DARK under the hybrid actor; lum=" lum))))
   ;; Tier b: the ENGINE default-invert darkens a themeless page at cascade time,
   ;; without any actor round-trip. Inject a white box and assert it computes
   ;; black — proving (A) sets mColorInversion at construction.
   (deftest "darkmode tier-b: engine default-invert darkens a themeless page (painted)" [mn ctx]
     (js/await (.setContext mn "chrome"))
     (chrome-eval HYBRID-B-JS)
     (let [lum (js/await (.executeAsyncScript mn (render-lum-js LIGHT-TOP 150 100) []))]
       (console/log (str "[dm-hybrid] tier-b /light center-lum=" lum))
       (expect (< (Number lum) 80) (str "themeless-light should invert to DARK under tier-b default-invert; lum=" lum))))
   ;; Tier b: a native-dark page (authored #111) is left un-inverted pre-paint by
   ;; PresShell::Initialize -> ApplyHybridDefaultInvertIfThemeless (it only flips
   ;; themeless pages), so it keeps its theme. After a settle (refiner could
   ;; otherwise re-invert), the root stays dark AND an injected white box stays
   ;; white (inversion is off for this doc).
   (deftest "darkmode tier-b: native-dark page keeps its theme — white probe stays white (painted)" [mn ctx]
     (js/await (.setContext mn "chrome"))
     (chrome-eval HYBRID-B-JS)
     ;; /dark bakes a white probe top-left (0,0,80,80). Native-dark is NOT inverted
     ;; pre-paint (PresShell::Initialize only flips themeless pages), so the white
     ;; probe STAYS WHITE; if inversion wrongly fired it would go black. Painted read.
     (let [lum (js/await (.executeAsyncScript mn (render-lum-js DARK-TOP 40 40) []))]
       (console/log (str "[dm-hybrid] tier-b /dark white-probe-lum=" lum))
       (expect (> (Number lum) 150) (str "native-dark must NOT invert: the white probe should stay WHITE; lum=" lum))))
   ;; v2 taxonomy regression guard: NO mode is OS-conditional anymore. The old
   ;; OS-branching "system" (whose dark branch was secretly the hybrid engine) is
   ;; gone. "dark" sets the pre-paint default-invert ON unconditionally (dark-first
   ;; on ANY OS); "system" is conventional follow-OS with default-invert OFF on any
   ;; OS. Spoof the OS via ui.systemUsesDarkTheme and assert default-invert tracks
   ;; the MODE, not the OS — i.e. flipping the OS must NOT move it in either mode.
   (deftest "darkmode v2: default-invert is per-mode, never OS-driven" [mn ctx]
     (js/await (.setContext mn "chrome"))
     ;; "dark": default-invert ON regardless of OS
     (chrome-eval (str "Services.prefs.setBoolPref('gjoa.darkmode.enabled', true);"
                       " Services.prefs.setStringPref('gjoa.darkmode.mode', 'dark');"
                       " return 'dark';"))
     (chrome-eval "Services.prefs.setIntPref('ui.systemUsesDarkTheme', 0); return 'os-light';")
     (js/await (await-true
                 "return Services.prefs.getBoolPref('gjoa.darkmode.hybrid.default-invert', false) === true;"
                 4000))
     (chrome-eval "Services.prefs.setIntPref('ui.systemUsesDarkTheme', 1); return 'os-dark';")
     (js/await (await-true
                 "return Services.prefs.getBoolPref('gjoa.darkmode.hybrid.default-invert', false) === true;"
                 4000))
     ;; "system": conventional follow-OS, default-invert OFF regardless of OS
     (chrome-eval "Services.prefs.setStringPref('gjoa.darkmode.mode', 'system'); return 'system';")
     (chrome-eval "Services.prefs.setIntPref('ui.systemUsesDarkTheme', 1); return 'os-dark';")
     (js/await (await-true
                 "return Services.prefs.getBoolPref('gjoa.darkmode.hybrid.default-invert', false) === false;"
                 4000))
     (chrome-eval "Services.prefs.setIntPref('ui.systemUsesDarkTheme', 0); return 'os-light';")
     (js/await (await-true
                 "return Services.prefs.getBoolPref('gjoa.darkmode.hybrid.default-invert', false) === false;"
                 4000)))
   ;; #49: an explicit per-site override (here a user.off entry for the fixture
   ;; host; the curated registry mirror works identically) is applied SYNCHRONOUSLY
   ;; at document-start — before PresShell::Initialize — so the engine's pre-paint
   ;; flip is pre-empted with no IPC round-trip. Validated via RESTART so the prefs
   ;; are in the content process's startup snapshot (set-then-navigate races the
   ;; parent->content pref propagation; production sets these at startup so it does
   ;; not). The themeless /light page must then NOT invert: a white box stays white.
   (deftest "darkmode #49: explicit override pre-empts the engine flip (sync, pre-paint)" [mn ctx]
     (js/await (.setContext mn "chrome"))
     (chrome-eval (str "Services.prefs.setBoolPref('gjoa.darkmode.enabled', true);"
                       " Services.prefs.setStringPref('gjoa.darkmode.mode', 'hybrid');"
                       " Services.prefs.setBoolPref('gjoa.darkmode.invert.enabled', false);"
                       " Services.prefs.setBoolPref('gjoa.darkmode.hybrid.default-invert', true);"
                       " Services.prefs.setStringPref('gjoa.darkmode.user.off', '127.0.0.1');"
                       " Services.prefs.savePrefFile(null);"
                       " return 'seeded';"))
     (let [client (js/await (.restartGjoa ctx))]
       (js/await (.setContext client "chrome"))
       (js/await (.executeAsyncScript client "const [r]=arguments; setTimeout(()=>r(1), 1500);" []))
       (let [navOk (js/await (.executeAsyncScript client NAV-JS [LIGHT-TOP]))]
         (expect navOk "light fixture loaded after restart")
         (js/await (.executeAsyncScript client SETTLE-JS []))
         (js/await (.setContext client "content"))
         (let [box (js/await (.executeAsyncScript client
                     (str "const [resolve]=arguments;"
                          " const d=document.createElement('div'); d.id='dm-w';"
                          " d.style.backgroundColor='rgb(255,255,255)';"
                          " document.body.appendChild(d);"
                          " setTimeout(()=>resolve(getComputedStyle(d).backgroundColor), 300);")
                     []))]
           (expect-eq box "rgb(255, 255, 255)"
                      (str "explicit override (inactive) did not pre-empt the engine flip; box=" box))))
       (js/await (.setContext client "chrome"))
       (js/await (.executeScript client
         (str "Services.prefs.clearUserPref('gjoa.darkmode.user.off');"
              " Services.prefs.clearUserPref('gjoa.darkmode.hybrid.default-invert');"
              " Services.prefs.clearUserPref('gjoa.darkmode.mode');"
              " Services.prefs.clearUserPref('gjoa.darkmode.enabled');"
              " Services.prefs.clearUserPref('gjoa.darkmode.invert.enabled');"
              " Services.prefs.savePrefFile(null);")
         []))))

   ;; Per-site override P2 — user.force-native (override='inactive', the mirror of
   ;; #49/off): "never invert this host". Default-invert would darken a themeless
   ;; /light page; force-native overrides -> it STAYS light. Painted, chrome-side.
   (deftest "darkmode override: user.force-native keeps a themeless-light page light (painted)" [mn ctx]
     (js/await (.setContext mn "chrome"))
     (chrome-eval HYBRID-B-JS)
     (chrome-eval "Services.prefs.setCharPref('gjoa.darkmode.user.force-native', '127.0.0.1'); return 'fn';")
     (let [lum (js/await (.executeAsyncScript mn (render-lum-js LIGHT-TOP 150 100) []))]
       (console/log (str "[dm-override] force-native /light center-lum=" lum))
       (expect (> (Number lum) 150) (str "force-native must KEEP themeless-light un-inverted (light); lum=" lum)))
     (chrome-eval "Services.prefs.clearUserPref('gjoa.darkmode.user.force-native'); return 'clean';"))

   ;; Per-site override P2 — user.force-invert (override='active'): "always invert
   ;; this host". A native-dark /dark page is normally KEPT; force-invert overrides
   ;; the keep -> #111 page bg inverts to a light center. Painted, chrome-side.
   (deftest "darkmode override: user.force-invert inverts a native-dark page (painted)" [mn ctx]
     (js/await (.setContext mn "chrome"))
     (chrome-eval HYBRID-B-JS)
     (chrome-eval "Services.prefs.setCharPref('gjoa.darkmode.user.force-invert', '127.0.0.1'); return 'fi';")
     (let [lum (js/await (.executeAsyncScript mn (render-lum-js DARK-TOP 150 100) []))]
       (console/log (str "[dm-override] force-invert /dark center-lum=" lum))
       (expect (> (Number lum) 150) (str "force-invert must invert the native-dark page (#111 -> light center); lum=" lum)))
     (chrome-eval "Services.prefs.clearUserPref('gjoa.darkmode.user.force-invert'); return 'clean';"))]))

(js/export-default tests)
