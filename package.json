{
  "name": "gjoa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Gjoa — a Firefox fork.",
  "scripts": {
    "init": "bun run download && bun run import",
    "download": "bun tools/prep/cli.ts download",
    "import": "bun tools/prep/cli.ts import",
    "clean": "bun tools/prep/cli.ts clean",
    "icons": "bun tools/icons/generate.ts",
    "chrome:bundle": "bun tools/chrome-bundle/build.ts",
    "chrome:watch": "bun --watch tools/chrome-bundle/build.ts",
    "chrome:dist": "bun tools/chrome-bundle/dist.ts",
    "chrome:install": "bun tools/chrome-bundle/install.ts",
    "test": "bun test"
  }
}
